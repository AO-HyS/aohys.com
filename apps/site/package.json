{
  "name": "@aohys/site",
  "version": "0.0.0",
  "private": true,
  "description": "Astro public SEO surface for aohys.com.",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "lint": "vitest run test/source-quality.test.ts",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit -p tsconfig.functions.json",
    "test": "vitest run test/analytics.test.ts test/dashboard-access.test.ts test/auth-proxy.test.ts && astro build && vitest run test/public-shell-build.test.ts test/public-routes-build.test.ts"
  },
  "dependencies": {
    "@aohys/content-graph": "workspace:*",
    "@aohys/core": "workspace:*",
    "@aohys/dashboard-ui": "workspace:*",
    "@aohys/environment": "workspace:*",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@fontsource-variable/mona-sans": "^5.2.8",
    "astro": "^7.0.3",
    "posthog-js": "^1.395.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
