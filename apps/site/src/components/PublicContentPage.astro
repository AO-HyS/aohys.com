          <h1 id="route-title">{variant.title}</h1>
          <p class={ui.heroLead}>{variant.summary}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondary)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <aside class={ui.routePanel} aria-label={copy.routeMetadataAria}>
          <span>{copy.canonical}</span>
          <strong>{route.path}</strong>
          <span>{copy.contentType}</span>
          <strong>{node.type}</strong>
        </aside>
      </section>

      <section class={ui.routeProofSection} aria-labelledby="route-proof-title">
        <div class={ui.sectionHeading}>
          <h2 id="route-proof-title">{copy.routeProofTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {copy.routeProof.map((item) => (
            <div class={ui.routeProofItem}>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>
    </>
  )
}
