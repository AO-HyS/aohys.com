---
import {
  getArchitecturePageContent,
  getCaseStudyIndexContent,
  getCaseStudyPageContent,
  getHomePageContent,
  getLocalizedPath,
  getPracticePageContent,
  getPrivacyPageContent,
  getResumePageContent,
  type ContentId,
  type PublicRoute,
} from "@aohys/content-graph";
import { DASHBOARD_PUBLIC_SETTINGS } from "../generated/dashboard-public-settings";
import { getUiCopy } from "../i18n";
import SunlitCtaBand from "./sunlit/SunlitCtaBand.astro";
import SunlitProjectStage from "./sunlit/SunlitProjectStage.astro";
import SunlitProofImage from "./sunlit/SunlitProofImage.astro";
import SunlitWebGLScene from "./sunlit/SunlitWebGLScene.astro";
import { resolveProofMedia } from "./sunlit/proof-media";

interface Props { route: PublicRoute; }

const { route } = Astro.props;
const { id, locale, node, variant } = route;
const uiCopy = getUiCopy(locale);
const copy = uiCopy.publicPage;
const contactCopy = uiCopy.contactForm;
const homeContent = getHomePageContent(locale);
const caseStudyIndexContent = getCaseStudyIndexContent(locale);
const architectureContent = id === "architecture" ? getArchitecturePageContent(locale) : undefined;
const practiceContent = id === "practice" ? getPracticePageContent(locale) : undefined;
const caseStudyContent = node.type === "case-study" ? getCaseStudyPageContent(id, locale) : undefined;
const resumeContent = node.type === "resume" ? getResumePageContent(locale) : undefined;
const privacyContent = node.type === "privacy" ? getPrivacyPageContent(locale) : undefined;
const isHome = id === "home";
const isPractice = id === "practice";
const isArchitecture = id === "architecture";
const isWorkIndex = node.type === "case-study-index";
const isCaseStudy = node.type === "case-study";
const isResume = node.type === "resume";
const isContact = node.type === "contact";
const isPrivacy = node.type === "privacy";
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";
const publicContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "alejandro.ortiz@aohys.com";
const publicWhatsAppUrl = DASHBOARD_PUBLIC_SETTINGS.PUBLIC_WHATSAPP_URL ?? import.meta.env.PUBLIC_WHATSAPP_URL ?? "https://wa.me/522299020825";
const directEmailHref = `mailto:${publicContactEmail}`;

const labels = uiCopy.sunlit.publicContent;
const serviceModes = labels.serviceModes;
const serviceSignals = labels.serviceSignals;
const architectureHeroNodes = labels.architectureHeroNodes;
const contactBriefPrompts = labels.contactBriefPrompts;

function localizedHref(contentId?: ContentId) {
  return contentId ? getLocalizedPath(contentId, locale) : undefined;
}

const primaryHref = localizedHref(variant.primaryActionContentId);
const secondaryHref = localizedHref(variant.secondaryActionContentId);
const routeActions = [
  { label: variant.primaryActionLabel, href: primaryHref, contentId: variant.primaryActionContentId },
  { label: variant.secondaryActionLabel, href: secondaryHref, contentId: variant.secondaryActionContentId },
].filter((action): action is { label: string; href: string; contentId: ContentId } => Boolean(action.label && action.href && action.contentId));
const contactRouteAction = routeActions.find((action) => action.contentId === "contact");
const secondaryRouteActions = routeActions.filter((action) => action.contentId !== "contact");
function mediaForContentId(contentId: string, evidenceSrc?: string, evidenceAlt?: string) {
  return resolveProofMedia(contentId, evidenceSrc, evidenceAlt ?? copy.mediaAlts.architecturePreview);
}

const caseMedia = isCaseStudy && caseStudyContent
  ? mediaForContentId(String(id), caseStudyContent.publicEvidence[0]?.src, caseStudyContent.publicEvidence[0]?.altText)
  : undefined;
const publicCaseSection = (section: { title: string; body: string }, title?: string) => (
  title ? { ...section, title } : section
);
const caseNarrativeBeats = caseStudyContent ? [
  { id: "project", title: labels.caseBeats[0], sections: [publicCaseSection(caseStudyContent.problem, labels.businessNeed), publicCaseSection(caseStudyContent.businessOutcome)] },
  { id: "role-system", title: labels.caseBeats[1], sections: [publicCaseSection(caseStudyContent.role), publicCaseSection(caseStudyContent.constraints, labels.considerations)] },
  { id: "decisions", title: labels.caseBeats[2], sections: [caseStudyContent.architectureDecisions] },
  { id: "delivery-quality", title: labels.caseBeats[3], sections: [caseStudyContent.executionHighlights, caseStudyContent.qualitySecurityPerformance] },
] : [];
const caseProjectLinks = caseStudyContent?.publicEvidence.filter((evidence) => evidence.href !== route.path) ?? [];
const isEnterpriseCase = id === "case-study:enterprise-systems";
---

{isHome ? (
  <>
    <section class="sunlit-studio-hero" aria-labelledby="home-title" data-home-content-id={id}>
      <div class="sunlit-hero-copy">
        <p class="sunlit-availability"><span aria-hidden="true"></span>{labels.available}</p>
        <h1 id="home-title">{homeContent.headline}</h1>
        <p class="sunlit-lead">{homeContent.deck}</p>
        <div class="sunlit-actions" aria-label={copy.actions}>
          <a class="sunlit-ticket-button" href={getLocalizedPath("contact", locale)}>{labels.talk}<span aria-hidden="true">→</span></a>
          <a class="sunlit-text-action" href={getLocalizedPath("case-studies", locale)}>{labels.viewWork}</a>
        </div>
      </div>
      <SunlitProjectStage
        outcomes={homeContent.selectedOutcomes}
        locale={locale}
        heading={labels.selectedStage}
        intro={labels.selectedStageIntro}
        hero
      />
    </section>

    <section class="sunlit-home-services" aria-labelledby="home-services-title">
      <header>
        <span>{labels.practice}</span>
        <h2 id="home-services-title">{homeContent.practiceHeading}</h2>
        <p>{homeContent.practiceBody}</p>
      </header>
      <div>
        {homeContent.practicePoints.map((point, index) => (
          <article><span>{String(index + 1).padStart(2, "0")}</span><h3>{point.label}</h3><p>{point.text}</p></article>
        ))}
      </div>
      <a class="sunlit-text-action" href={getLocalizedPath("practice", locale)}>{labels.seeServices}<span aria-hidden="true">→</span></a>
    </section>

    <section class="sunlit-home-split" aria-labelledby="home-architecture-title">
      <div class="sunlit-split-copy">
        <span>{labels.architecture}</span>
        <h2 id="home-architecture-title">{homeContent.architectureHeading}</h2>
        <p>{homeContent.architectureBody}</p>
        <a class="sunlit-text-action" href={getLocalizedPath("architecture", locale)}>{labels.architecture}<span aria-hidden="true">→</span></a>
      </div>
      <div class="sunlit-boundary-map" aria-label={homeContent.proofBoardLabel}>
        {homeContent.architectureStages.map((stage, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{stage.label}</h3>
            <p>{stage.text}</p>
          </article>
        ))}
        <i aria-hidden="true"></i>
      </div>
    </section>

    <SunlitCtaBand
      heading={homeContent.contactHeading}
      body={homeContent.contactBody}
      href={getLocalizedPath("contact", locale)}
      label={variant.primaryActionLabel ?? labels.talk}
      secondaryHref={directEmailHref}
      secondaryLabel={homeContent.emailLabel}
    />
  </>
) : isWorkIndex ? (
  <>
    <section class="sunlit-page-hero sunlit-work-hero" aria-labelledby="work-title" data-case-study-index-content-id={id}>
      <div>
        <p>{labels.workArchive}</p>
        <h1 id="work-title">{caseStudyIndexContent.heading}</h1>
        <p>{caseStudyIndexContent.intro}</p>
      </div>
    </section>

    <section class="sunlit-work-archive" aria-label={labels.workArchive}>
      <header>
        <h2>{labels.workArchive}</h2>
        <p>{labels.workArchiveBody}</p>
      </header>
      <div class="sunlit-archive-list">
        {caseStudyIndexContent.entries.map((entry, index) => {
          const entryDetail = getCaseStudyPageContent(entry.contentId, locale);
          const entryMedia = mediaForContentId(
            String(entry.contentId),
            entryDetail?.publicEvidence[0]?.src,
            entryDetail?.publicEvidence[0]?.altText ?? entry.evidenceLabel,
          );
          return (
            <article data-tone={index % 3}>
              <figure data-media-kind={entryMedia.kind}>
                <SunlitProofImage
                  contentId={String(entry.contentId)}
                  evidenceSrc={entryDetail?.publicEvidence[0]?.src}
                  alt={entryDetail?.publicEvidence[0]?.altText ?? entry.evidenceLabel}
                  evidenceKind={entryDetail?.publicEvidence[0]?.kind}
                  loading="eager"
                />
              </figure>
              <div>
                <p>{entry.statusLabel}</p>
                <h3>{entry.title}</h3>
                <p>{entry.summary}</p>
                <a class="sunlit-text-action" href={entry.path}>{labels.readCase}<span aria-hidden="true">→</span></a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : isPractice && practiceContent ? (
  <>
    <section class="sunlit-page-hero sunlit-practice-hero" aria-labelledby="practice-title" data-practice-content-id={id}>
      <div>
        <p>{labels.practice}</p>
        <h1 id="practice-title">{practiceContent.heading}</h1>
        <p>{practiceContent.deck}</p>
        <div class="sunlit-actions">
          {contactRouteAction && <a class="sunlit-ticket-button" href={contactRouteAction.href}>{labels.talk}</a>}
          {secondaryRouteActions.map((action) => <a class="sunlit-text-action" href={action.href}>{action.label}</a>)}
        </div>
      </div>
      <nav class="sunlit-service-menu" aria-label={labels.serviceMode}>
        <p>{labels.serviceMode}</p>
        {practiceContent.services.map((service, index) => (
          <a href={`#${service.id}`}>
            <span aria-hidden="true">{serviceModes[index]?.symbol}</span>
            <span><small>{serviceModes[index]?.kicker}</small><strong>{service.title}</strong><em>{serviceModes[index]?.note}</em></span>
            <i aria-hidden="true">↓</i>
          </a>
        ))}
      </nav>
    </section>

    <section class="sunlit-service-list" aria-label={labels.practice}>
      {practiceContent.services.map((service, index) => (
        <article id={service.id} class="sunlit-service-offer" data-service-pattern={["new", "team", "modernize"][index]}>
          <header>
            <span aria-hidden="true">{serviceModes[index]?.symbol}</span>
            <div><p>{serviceModes[index]?.kicker}</p><h2>{service.title}</h2></div>
          </header>
          <div class="sunlit-service-signal" aria-hidden="true">
            {serviceSignals[index]?.items.map((item, signalIndex) => (
              signalIndex === serviceSignals[index]?.emphasisIndex ? <strong>{item}</strong> : <span>{item}</span>
            ))}
          </div>
          <div class="sunlit-service-fit"><strong>{labels.serviceFit}</strong><p>{service.problem}</p></div>
          <div class="sunlit-service-result"><strong>{labels.serviceResult}</strong><p>{service.result}</p></div>
          <div class="sunlit-service-collaboration"><strong>{labels.serviceCollaboration}</strong><p>{service.engagement}</p></div>
          <div class="sunlit-service-outputs">
            <strong>{labels.serviceOutputs}</strong>
            <ul>{service.deliverables.map((deliverable) => <li>{deliverable}</li>)}</ul>
          </div>
        </article>
      ))}
    </section>

    <section class="sunlit-service-process" aria-labelledby="service-process-title">
      <header><span>{labels.process}</span><h2 id="service-process-title">{practiceContent.processHeading}</h2></header>
      <div>{practiceContent.process.map((step, index) => (
        <article><span>{String(index + 1).padStart(2, "0")}</span><h3>{step.label}</h3><p>{step.text}</p></article>
      ))}</div>
    </section>

    <section class="sunlit-service-deliverables" aria-labelledby="service-deliverables-title">
      <div><h2 id="service-deliverables-title">{practiceContent.deliverablesHeading}</h2></div>
      <ul>{practiceContent.deliverables.map((deliverable) => <li>{deliverable}</li>)}</ul>
      <nav aria-label={practiceContent.relatedHeading}>
        <strong>{practiceContent.relatedHeading}</strong>
        {practiceContent.relatedContentIds.map((contentId) => (
          <a class="sunlit-text-action" href={getLocalizedPath(contentId, locale)}>{contentId === "architecture" ? labels.architecture : labels.work}<span aria-hidden="true">→</span></a>
        ))}
      </nav>
    </section>

    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : isArchitecture && architectureContent ? (
  <>
    <section class="sunlit-page-hero sunlit-architecture-hero" aria-labelledby="architecture-title" data-architecture-content-id={id}>
      <div>
        <p>{labels.architecture}</p>
        <h1 id="architecture-title">{architectureContent.heading}</h1>
        <p>{architectureContent.deck}</p>
        <div class="sunlit-actions">
          {contactRouteAction && <a class="sunlit-ticket-button" href={contactRouteAction.href}>{labels.talk}</a>}
          {secondaryRouteActions.map((action) => <a class="sunlit-text-action" href={action.href}>{action.label}</a>)}
        </div>
      </div>
      <div class="sunlit-architecture-hero-map" aria-labelledby="architecture-hero-map-title">
        <SunlitWebGLScene variant="architecture" label={labels.architectureSceneLabel} />
        <div class="sunlit-architecture-topology">
          <header>
            <span>{labels.architectureLiveSystem}</span>
            <strong id="architecture-hero-map-title">{labels.architectureFlow}</strong>
          </header>
          <ol>
            {architectureHeroNodes.map((node, index) => (
              <li data-system-node={node.id}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div><strong>{node.title}</strong><p>{node.detail}</p><small>{node.meta}</small></div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="sunlit-system-map" aria-labelledby="system-map-title">
      <header><span>{labels.architecture}</span><h2 id="system-map-title">{architectureContent.systemHeading}</h2><p>{architectureContent.systemBody}</p></header>
      <ol class="sunlit-system-layers">
        {architectureContent.layers.map((layer, index) => (
          <li data-layer={layer.id}>
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{layer.label}</h3>
              <p>{layer.body}</p>
              <ul>{layer.technologies.map((technology) => <li>{technology}</li>)}</ul>
            </article>
          </li>
        ))}
      </ol>
    </section>

    <section class="sunlit-architecture-tradeoffs" aria-labelledby="tradeoffs-title">
      <header><h2 id="tradeoffs-title">{architectureContent.tradeoffsHeading}</h2></header>
      <ol>{architectureContent.tradeoffs.map((tradeoff, index) => (
        <li>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div><h3>{tradeoff.title}</h3><p>{tradeoff.reason}</p></div>
          <strong>{tradeoff.result}</strong>
        </li>
      ))}</ol>
    </section>

    <section class="sunlit-architecture-notes" aria-labelledby="architecture-notes-title">
      <header><h2 id="architecture-notes-title">{labels.architectureNotes}</h2><p>{labels.architectureNotesIntro}</p></header>
      <ol>{architectureContent.sections.map((section, index) => (
        <li><span>{String(index + 1).padStart(2, "0")}</span><div><h3>{section.title}</h3><p>{section.body}</p>{section.links && <div>{section.links.map((link) => <a class="sunlit-text-action" href={link.href}>{link.label} ↗</a>)}</div>}</div></li>
      ))}</ol>
    </section>

    <nav class="sunlit-source-links" aria-label={architectureContent.sourceLabel}>
      <strong>{architectureContent.sourceLabel}</strong>
      <div>{architectureContent.sourceLinks.map((link) => <a class="sunlit-text-action" href={link.href}>{link.label}<i aria-hidden="true">↗</i></a>)}</div>
    </nav>

    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : isCaseStudy && caseStudyContent && caseMedia ? (
  <>
    <article class="sunlit-case" data-case-study-content-id={id}>
      <header class="sunlit-case-hero">
        <div>
          <p>{caseStudyContent.statusLabel}</p>
          <h1>{variant.title}</h1>
          <p>{caseStudyContent.overview}</p>
          <div class="sunlit-actions">
            {contactRouteAction && <a class="sunlit-ticket-button" href={contactRouteAction.href}>{labels.talk}</a>}
            {secondaryRouteActions.map((action) => <a class="sunlit-text-action" href={action.href}>{action.label}</a>)}
          </div>
          {caseProjectLinks.length > 0 && (
            <nav class="sunlit-case-hero-links" aria-label={labels.evidence}>
              {caseProjectLinks.map((evidence) => (
                <a class="sunlit-text-action" href={evidence.href} aria-label={evidence.altText}>{evidence.label}<span aria-hidden="true">↗</span></a>
              ))}
            </nav>
          )}
        </div>
        <figure data-media-kind={caseMedia.kind}>
          <span class="sunlit-hanger" aria-hidden="true"></span>
          <SunlitProofImage
            contentId={String(id)}
            evidenceSrc={caseStudyContent.publicEvidence[0]?.src}
            alt={caseStudyContent.publicEvidence[0]?.altText}
            evidenceKind={caseStudyContent.publicEvidence[0]?.kind}
            loading="eager"
            preferFull
          />
          <figcaption>{caseStudyContent.statusLabel}</figcaption>
        </figure>
      </header>

      <div class="sunlit-case-rail" aria-label={labels.casePath}>
        {caseNarrativeBeats.map((beat, index) => (
          <section data-case-beat={beat.id}>
            <header><span aria-hidden="true">{["↗", "◎", "◇", "✓"][index]}</span><h2>{beat.title}</h2></header>
            <div>{beat.sections.map((section) => <article><h3>{section.title}</h3><p>{section.body}</p></article>)}</div>
          </section>
        ))}
      </div>

      {isEnterpriseCase && <p class="sunlit-client-note">{caseStudyContent.confidentialityNote.body}</p>}
    </article>

    <section class="sunlit-related" aria-labelledby="related-title">
      <h2 id="related-title">{labels.related}</h2>
      <div>
        {caseStudyIndexContent.entries.filter((entry) => entry.contentId !== id).map((entry) => (
          <a href={entry.path}><span>{entry.statusLabel}</span><strong>{entry.title}</strong><i aria-hidden="true">→</i></a>
        ))}
      </div>
    </section>

    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : isResume && resumeContent ? (
  <>
    <section class="sunlit-page-hero sunlit-about-hero" aria-labelledby="about-title" data-resume-content-id={id}>
      <div>
        <p>{labels.about}</p>
        <h1 id="about-title">{resumeContent.name}</h1>
        <p class="sunlit-about-role">{resumeContent.role} · {resumeContent.location}</p>
        <p>{resumeContent.intro}</p>
        <div class="sunlit-actions">
          <a class="sunlit-ticket-button" href={getLocalizedPath("contact", locale)}>{labels.talk}</a>
          <a class="sunlit-text-action" href={resumeContent.pdf.href}>{labels.download}</a>
        </div>
      </div>
      <aside class="sunlit-profile-ticket">
        <span>{resumeContent.proof.label}</span>
        <h2>{resumeContent.proof.title}</h2>
        <p>{resumeContent.proof.body}</p>
        <i aria-hidden="true">✓</i>
      </aside>
    </section>

    <section class="sunlit-profile-summary" aria-labelledby="profile-title">
      <header><h2 id="profile-title">{resumeContent.summaryTitle}</h2></header>
      <div>{resumeContent.summary.map((paragraph) => <p>{paragraph}</p>)}</div>
      <aside>{resumeContent.highlights.map((highlight) => <div><strong>{highlight.label}</strong><p>{highlight.text}</p></div>)}</aside>
    </section>

    <section class="sunlit-profile-projects" aria-labelledby="projects-title">
      <header><h2 id="projects-title">{resumeContent.projectsTitle}</h2></header>
      <div>{resumeContent.projects.map((project) => <article><h3>{project.title}</h3><p>{project.summary}</p><ul>{project.bullets.map((bullet) => <li>{bullet}</li>)}</ul></article>)}</div>
    </section>

    <section class="sunlit-experience" aria-labelledby="experience-title">
      <header><h2 id="experience-title">{resumeContent.experienceTitle}</h2></header>
      <div>
        {resumeContent.experience.map((job, index) => (
          <article><span>{String(index + 1).padStart(2, "0")}</span><div><h3>{job.role}</h3><p>{job.company} · {job.period}</p><ul>{job.bullets.map((bullet) => <li>{bullet}</li>)}</ul></div></article>
        ))}
      </div>
    </section>

    <section class="sunlit-capabilities" aria-labelledby="capabilities-title">
      <header><h2 id="capabilities-title">{resumeContent.skillsTitle}</h2></header>
      <div>{resumeContent.skills.map((group) => <article><h3>{group.label}</h3><p>{group.items.join(" · ")}</p></article>)}</div>
    </section>

    <section class="sunlit-education" aria-labelledby="education-title">
      <header><h2 id="education-title">{resumeContent.educationTitle}</h2></header>
      <div>{resumeContent.education.map((item) => <p><strong>{item.degree}</strong><span>{item.institution} · {item.period}</span></p>)}</div>
      <p>{resumeContent.languagesTitle}: {resumeContent.languages.join(" · ")}</p>
    </section>

    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : isContact ? (
  <>
    <section class="sunlit-page-hero sunlit-contact-hero" aria-labelledby="contact-title" data-contact-content-id={id}>
      <div>
        <p>{labels.contactRail}</p>
        <h1 id="contact-title">{variant.title}</h1>
        <p>{variant.summary}</p>
        <div class="sunlit-contact-hero-direct">
          <a class="sunlit-text-action" href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_direct_panel">{contactCopy.whatsappLabel}<span aria-hidden="true">↗</span></a>
          <a class="sunlit-text-action" href={directEmailHref} data-analytics-event="email_cta_clicked" data-analytics-target="contact_direct_panel">{publicContactEmail}<span aria-hidden="true">↗</span></a>
        </div>
      </div>
      <div class="sunlit-contact-visual">
        <SunlitWebGLScene variant="contact" label={labels.contactSceneLabel} />
        <article class="sunlit-project-brief" aria-labelledby="contact-brief-title">
          <header><span>{labels.contactBriefLabel}</span><h2 id="contact-brief-title">{labels.contactBriefTitle}</h2></header>
          <dl>
            {contactBriefPrompts.map(([term, description]) => <div><dt>{term}</dt><dd>{description}</dd></div>)}
          </dl>
          <p><span aria-hidden="true">↗</span>{labels.contactBriefReply}</p>
        </article>
      </div>
    </section>

    <section class="sunlit-contact-layout" aria-label={contactCopy.formTitle}>
      <aside>
        <span>{labels.direct}</span>
        <h2>{contactCopy.formTitle}</h2>
        <p>{contactCopy.formIntro}</p>
      </aside>
      <form
        method="post"
        action={contactEndpoint || directEmailHref}
        data-contact-form
        data-contact-endpoint={contactEndpoint}
        data-success-message={contactCopy.successMessage}
        data-degraded-success-message={contactCopy.degradedSuccessMessage}
        data-error-message={contactCopy.errorMessage}
        data-validation-message={contactCopy.validationMessage}
        data-rate-limited-message={contactCopy.rateLimitedMessage}
        data-email-error-message={contactCopy.emailErrorMessage}
        data-backend-error-message={contactCopy.backendErrorMessage}
        data-endpoint-missing={contactCopy.endpointMissing}
        data-retry-label={contactCopy.retryLabel}
        data-analytics-view="contact_form_viewed"
        data-analytics-submit="contact_form_submit_attempted"
        data-analytics-target="contact_form"
      >
        <label><span>{contactCopy.nameLabel}</span><input name="name" type="text" autocomplete="name" required /></label>
        <div class="sunlit-field-grid">
          <label><span>{contactCopy.emailLabel}</span><input name="email" type="email" autocomplete="email" required aria-required="true" /></label>
          <label><span>{contactCopy.phoneLabel}<small id="contact-phone-requirement" data-phone-requirement data-optional-label={contactCopy.phoneOptionalHint} data-required-label={contactCopy.phoneRequiredHint}>{contactCopy.phoneOptionalHint}</small></span><input name="phone" type="tel" autocomplete="tel" data-contact-phone aria-required="false" aria-describedby="contact-phone-requirement contact-path-help" /></label>
        </div>
        <label><span>{contactCopy.companyLabel}</span><input name="company" type="text" autocomplete="organization" /></label>
        <div class="sunlit-field-grid">
          <label><span>{contactCopy.intentLabel}</span><select name="intent" required><option value="project">{contactCopy.intentProject}</option><option value="hiring">{contactCopy.intentHiring}</option><option value="architecture-review">{contactCopy.intentArchitecture}</option><option value="website">{contactCopy.intentWebsite}</option><option value="other">{contactCopy.intentOther}</option></select></label>
          <fieldset aria-describedby="contact-path-help"><legend>{contactCopy.preferredContactLabel}</legend><label><input name="preferredContactPath" type="radio" value="email" required checked /><span>{contactCopy.preferredEmail}</span></label><label><input name="preferredContactPath" type="radio" value="whatsapp" required /><span>{contactCopy.preferredWhatsApp}</span></label><p id="contact-path-help">{contactCopy.preferredContactHelp}</p></fieldset>
        </div>
        <label><span>{contactCopy.messageLabel}</span><textarea name="message" rows="6" placeholder={contactCopy.messagePlaceholder} required></textarea></label>
        <label class="sunlit-consent"><input name="consentToContact" type="checkbox" value="true" required /><span>{contactCopy.consentLabel}</span></label>
        <label class="sunlit-honeypot" aria-hidden="true"><span>{contactCopy.honeypotLabel}</span><input name="website" type="text" autocomplete="off" tabindex="-1" /></label>
        <input name="formStartedAt" type="hidden" value="" />
        <input name="sourcePath" type="hidden" value={route.path} />
        <input name="locale" type="hidden" value={locale} />
        <input name="referrer" type="hidden" value="" />
        <div class="sunlit-submit"><button class="sunlit-ticket-button" type="submit" data-submit-label={contactCopy.submitLabel} data-sending-label={contactCopy.sendingLabel}>{contactCopy.submitLabel}<span aria-hidden="true">→</span></button><p>{contactCopy.fallbackText} <a href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_form_error_fallback">{contactCopy.whatsappLabel}</a></p></div>
        <p class="sunlit-contact-status" role="status" data-contact-status></p>
      </form>
    </section>

    <script>
      const dispatchContactAnalytics = (event: string, properties: Record<string, string | boolean> = {}) => {
        window.dispatchEvent(new CustomEvent("aohys:analytics", { detail: { event, properties } }));
      };
      const messageWithRetry = (message: string | undefined, retry: string | undefined) => [message, retry].filter(Boolean).join(" ");
      const readJson = async (response: Response) => { try { return await response.json(); } catch { return {}; } };
      const stringStatus = (payload: unknown, key: string, fallback: string) => {
        if (!payload || typeof payload !== "object") return fallback;
        const value = (payload as Record<string, unknown>)[key];
        return typeof value === "string" && value ? value : fallback;
      };
      for (const candidate of document.querySelectorAll("[data-contact-form]")) {
        if (!(candidate instanceof HTMLFormElement)) continue;
        const form = candidate;
        const status = form.querySelector("[data-contact-status]");
        const startedAt = form.querySelector('input[name="formStartedAt"]');
        const referrer = form.querySelector('input[name="referrer"]');
        const submitButton = form.querySelector('button[type="submit"]');
        const phoneInput = form.querySelector("[data-contact-phone]");
        const phoneRequirement = form.querySelector("[data-phone-requirement]");
        const preferredContactOptions = Array.from(form.querySelectorAll('input[name="preferredContactPath"]')).filter((input): input is HTMLInputElement => input instanceof HTMLInputElement);
        const syncPreferredContactRequirements = () => {
          const whatsappSelected = preferredContactOptions.some((input) => input.checked && input.value === "whatsapp");
          if (phoneInput instanceof HTMLInputElement) {
            phoneInput.required = whatsappSelected;
            phoneInput.setAttribute("aria-required", String(whatsappSelected));
          }
          if (phoneRequirement instanceof HTMLElement) {
            phoneRequirement.textContent = whatsappSelected ? phoneRequirement.dataset.requiredLabel ?? "" : phoneRequirement.dataset.optionalLabel ?? "";
          }
        };
        preferredContactOptions.forEach((input) => input.addEventListener("change", syncPreferredContactRequirements));
        syncPreferredContactRequirements();
        if (startedAt instanceof HTMLInputElement) startedAt.value = String(Date.now());
        if (referrer instanceof HTMLInputElement) referrer.value = document.referrer;
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          if (!form.checkValidity()) {
            if (status instanceof HTMLElement) { status.dataset.state = "error"; status.textContent = messageWithRetry(form.dataset.validationMessage, form.dataset.retryLabel); }
            dispatchContactAnalytics("contact_form_submit_failed", { failure_reason: "validation_failed" });
            form.reportValidity(); return;
          }
          const endpoint = form.dataset.contactEndpoint ?? "";
          if (!endpoint) {
            if (status instanceof HTMLElement) { status.dataset.state = "error"; status.textContent = messageWithRetry(form.dataset.endpointMissing, form.dataset.retryLabel); }
            dispatchContactAnalytics("contact_form_submit_failed", { failure_reason: "endpoint_missing" }); return;
          }
          const formData = new FormData(form);
          const payload = Object.fromEntries(formData.entries());
          if (submitButton instanceof HTMLButtonElement) { submitButton.disabled = true; submitButton.textContent = submitButton.dataset.sendingLabel ?? submitButton.textContent; }
          if (status instanceof HTMLElement) { status.dataset.state = "sending"; status.textContent = ""; }
          try {
            const response = await fetch(endpoint, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ ...payload, consentToContact: formData.get("consentToContact") === "true", formStartedAt: Number(payload.formStartedAt) }) });
            const result = await readJson(response);
            if (!response.ok) {
              const code = stringStatus(result, "code", "");
              const reason = response.status === 429 || code === "rate_limited" ? "rate_limited" : response.status === 400 || code === "validation_error" ? "validation_failed" : code.includes("email") || code.includes("provider") ? "email_delivery_failed" : "backend_unavailable";
              dispatchContactAnalytics("contact_form_submit_failed", { failure_reason: reason });
              const message = reason === "rate_limited" ? form.dataset.rateLimitedMessage : reason === "validation_failed" ? form.dataset.validationMessage : reason === "email_delivery_failed" ? form.dataset.emailErrorMessage : form.dataset.backendErrorMessage;
              if (status instanceof HTMLElement) { status.dataset.state = "error"; status.textContent = messageWithRetry(message, form.dataset.retryLabel); }
              return;
            }
            const notificationStatus = stringStatus(result, "notificationStatus", "unknown");
            const analyticsStatus = stringStatus(result, "analyticsStatus", "unknown");
            const deliveryDegraded = notificationStatus === "failed" || notificationStatus === "skipped";
            dispatchContactAnalytics("contact_form_submit_succeeded", { notification_status: notificationStatus, analytics_status: analyticsStatus, delivery_degraded: deliveryDegraded });
            form.reset();
            syncPreferredContactRequirements();
            if (status instanceof HTMLElement) { status.dataset.state = deliveryDegraded ? "warning" : "success"; status.textContent = deliveryDegraded ? form.dataset.degradedSuccessMessage ?? form.dataset.successMessage ?? "" : form.dataset.successMessage ?? ""; }
          } catch {
            dispatchContactAnalytics("contact_form_submit_failed", { failure_reason: "backend_unavailable" });
            if (status instanceof HTMLElement) { status.dataset.state = "error"; status.textContent = messageWithRetry(form.dataset.backendErrorMessage, form.dataset.retryLabel); }
          } finally {
            if (submitButton instanceof HTMLButtonElement) { submitButton.disabled = false; submitButton.textContent = submitButton.dataset.submitLabel ?? submitButton.textContent; }
          }
        });
      }
    </script>
  </>
) : isPrivacy && privacyContent ? (
  <>
    <section class="sunlit-page-hero sunlit-privacy-hero" aria-labelledby="privacy-title" data-privacy-content-id={id}>
      <div><p>{labels.privacyRail}</p><h1 id="privacy-title">{privacyContent.heading}</h1><p>{privacyContent.intro}</p></div>
      <aside aria-hidden="true"><span>✓</span><strong>{labels.privacyRail}</strong></aside>
    </section>
    <article class="sunlit-legal">
      {privacyContent.sections.map((section, index) => <section><span>{String(index + 1).padStart(2, "0")}</span><div><h2>{section.title}</h2><p>{section.body}</p></div></section>)}
      <footer><strong>{labels.constraints}</strong><p>{privacyContent.boundaryNote}</p></footer>
    </article>
    <SunlitCtaBand heading={homeContent.contactHeading} body={homeContent.contactBody} href={getLocalizedPath("contact", locale)} label={labels.talk} />
  </>
) : (
  <section class="sunlit-page-hero" aria-labelledby="route-title" data-content-type={node.type}>
    <div><p>{copy.signal}</p><h1 id="route-title">{variant.title}</h1><p>{variant.summary}</p></div>
  </section>
)}

