}

function evidenceImageForPath(path: string) {
  const normalizedPath = path.replace(/\/$/, "");
  const dynamicSlug = normalizedPath.match(/^\/case-studies\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1]
    ?? normalizedPath.match(/^\/es\/casos\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1];

  if (dynamicSlug) {
    const dynamicImage = evidenceImageForContent(`case-study:${dynamicSlug}`);

    if (dynamicImage) {
      return dynamicImage;
    }
  }

  if (path.includes("casa-roca")) {
    return evidenceImageForContent("case-study:casa-roca");
  }

  if (path.includes("the-barber-central")) {
    return evidenceImageForContent("case-study:the-barber-central");
  }

  if (path.includes("nutri-plan")) {
    return evidenceImageForContent("case-study:nutri-plan");
  }

  if (path.includes("enterprise-systems") || path.includes("sistemas-enterprise")) {
    return evidenceImageForContent("case-study:enterprise-systems");
  }

  if (
    path.includes("engineering-practice") ||
    path.includes("practica-de-ingenieria") ||
    path === "/practice" ||
    path === "/es/practica"
  ) {
    return evidenceImageForContent("case-study:engineering-practice");
  }

  return undefined;
}

