  /* Sunlit Systems Studio: shared page rhythm and route-specific modules. */
  .sunlit-studio-hero {
    display: grid;
    width: var(--container);
    min-height: calc(100svh - 4.5rem);
    margin: 0 auto;
    grid-template-columns: minmax(26rem, .86fr) minmax(34rem, 1.14fr);
