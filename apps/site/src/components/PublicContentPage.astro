---
import {
  getArchitecturePageContent,
  getCaseStudyIndexContent,
  getCaseStudyPageContent,
  getHomePageContent,
  getLocalizedPath,
  getPrivacyPageContent,
  getResumePageContent,
  STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID,
  type ContentId,
  type PublicRoute,
} from "@aohys/content-graph";
import { DASHBOARD_PUBLIC_MEDIA_BY_CONTENT_ID } from "../generated/dashboard-public-media";
import { DASHBOARD_PUBLIC_SETTINGS } from "../generated/dashboard-public-settings";
import { getUiCopy } from "../i18n";
import { cx, proofImageClass, screenshotImageClass, ui } from "../styles/classes";

interface Props {
  route: PublicRoute;
}

const { route } = Astro.props;
const { id, locale, node, variant } = route;
const isHome = id === "home";
const isArchitecture = id === "architecture";
const isCaseStudyIndex = node.type === "case-study-index";
const isCaseStudy = node.type === "case-study";
const isResume = node.type === "resume";
const isContact = node.type === "contact";
const isPrivacy = node.type === "privacy";
const copy = getUiCopy(locale).publicPage;
const contactCopy = getUiCopy(locale).contactForm;
const homeContent = isHome ? getHomePageContent(locale) : undefined;
const architectureContent = isArchitecture ? getArchitecturePageContent(locale) : undefined;
const caseStudyIndexContent = isCaseStudyIndex ? getCaseStudyIndexContent(locale) : undefined;
const caseStudyContent = isCaseStudy ? getCaseStudyPageContent(id, locale) : undefined;
const resumeContent = isResume ? getResumePageContent(locale) : undefined;
const privacyContent = isPrivacy ? getPrivacyPageContent(locale) : undefined;
const caseStudySections = caseStudyContent ? [
  caseStudyContent.problem,
  caseStudyContent.businessOutcome,
  caseStudyContent.role,
  caseStudyContent.constraints,
  caseStudyContent.architectureDecisions,
  caseStudyContent.executionHighlights,
  caseStudyContent.qualitySecurityPerformance,
] : [];

function actionHref(contentId?: ContentId): string | undefined {
  return contentId ? getLocalizedPath(contentId, locale) : undefined;
}

const primaryHref = actionHref(variant.primaryActionContentId);
const secondaryHref = actionHref(variant.secondaryActionContentId);
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";
const publicContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "alejandro.ortiz@aohys.com";
const publicWhatsAppUrl = DASHBOARD_PUBLIC_SETTINGS.PUBLIC_WHATSAPP_URL ?? import.meta.env.PUBLIC_WHATSAPP_URL ?? "https://wa.me/522299020825";
const directEmailHref = `mailto:${publicContactEmail}`;

function splitHeadline(headline: string): string[] {
  const parts = headline.split(". ");
  return parts.map((part, index) => {
    if (index < parts.length - 1 && !part.endsWith(".")) {
      return `${part}.`;
    }

    return part;
  });
}

const homeHeadlineParts = homeContent ? splitHeadline(homeContent.headline) : [];

const routeSignalById: Partial<Record<ContentId | string, string>> = {
  "case-studies": locale === "es" ? "Trabajo que puedo mostrar" : "Work I can show",
  architecture: locale === "es" ? "Sistema público" : "Public system",
  resume: locale === "es" ? "Contexto profesional" : "Professional context",
  contact: locale === "es" ? "Contacto directo" : "Direct contact",
  privacy: locale === "es" ? "Límite de privacidad" : "Privacy boundary",
  practice: locale === "es" ? "Práctica de ingeniería" : "Engineering practice",
};
const routeSignal = routeSignalById[id] ?? variant.summary;

const fallbackEvidenceImageByContentId: Partial<Record<ContentId | string, { src: string; thumbSrc?: string; alt: string; kind: string }>> = {
  "case-study:casa-roca": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:casa-roca"],
    alt: locale === "es" ? "Captura pública del sitio Casa Roca en producción" : "Public Casa Roca production website screenshot",
  },
  "case-study:the-barber-central": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:the-barber-central"],
    alt: locale === "es" ? "Landing page de desarrollo de The Barber Central" : "The Barber Central development landing page",
  },
  "case-study:nutri-plan": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:nutri-plan"],
    alt: locale === "es" ? "Dashboard administrativo de Nutri Plan" : "Nutri Plan administrative dashboard",
  },
  "case-study:enterprise-systems": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:enterprise-systems"],
    alt: locale === "es" ? "Mapa público seguro de trabajo enterprise confidencial" : "Public-safe map of confidential enterprise systems work",
  },
  "case-study:engineering-practice": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:engineering-practice"],
    alt: locale === "es" ? "Superficie visual de arquitectura pública de AOHYS" : "AOHYS public architecture proof surface",
  },
};
const evidenceImageByContentId: Partial<Record<ContentId | string, { src: string; thumbSrc?: string; alt: string; kind: string }>> = {
  ...fallbackEvidenceImageByContentId,
  ...DASHBOARD_PUBLIC_MEDIA_BY_CONTENT_ID,
};

function evidenceImageForContent(contentId: string) {
  return evidenceImageByContentId[contentId];
}

function evidenceImageForPath(path: string) {
  const normalizedPath = path.replace(/\/$/, "");
  const dynamicSlug = normalizedPath.match(/^\/case-studies\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1]
    ?? normalizedPath.match(/^\/es\/casos\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1];

  if (dynamicSlug) {
    const dynamicImage = evidenceImageForContent(`case-study:${dynamicSlug}`);

    if (dynamicImage) {
      return dynamicImage;
    }
  }

  if (path.includes("casa-roca")) {
    return evidenceImageForContent("case-study:casa-roca");
  }

  if (path.includes("the-barber-central")) {
    return evidenceImageForContent("case-study:the-barber-central");
  }

  if (path.includes("nutri-plan")) {
    return evidenceImageForContent("case-study:nutri-plan");
  }

  if (path.includes("enterprise-systems") || path.includes("sistemas-enterprise")) {
    return evidenceImageForContent("case-study:enterprise-systems");
  }

  if (
    path.includes("engineering-practice") ||
    path.includes("practica-de-ingenieria") ||
    path === "/practice" ||
    path === "/es/practica"
  ) {
    return evidenceImageForContent("case-study:engineering-practice");
  }

  return undefined;
}

const caseStudyEvidenceImage = isCaseStudy ? evidenceImageForContent(id) : undefined;
---

{
  isHome && homeContent ? (
    <>
      <section class={ui.homeProofHero} aria-labelledby="home-title" data-home-content-id={id}>
        <div class={ui.homeHeroCopy}>
          <p class={cx(ui.signalLine, ui.homeSignalLine)}>{copy.signal}</p>
          <h1 id="home-title" class={ui.homeHeadline} aria-label={homeContent.headline}>
            {homeHeadlineParts.map((part) => <span aria-hidden="true">{part}</span>)}
          </h1>
          <p class={cx(ui.heroLead, ui.homeHeroLead)}>
            {homeContent.deck}
          </p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnLightHero)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <figure class={cx(ui.proofBoard, ui.homeProofBoard)} aria-label={homeContent.proofBoardLabel}>
          <img
            class={ui.heroArtifactAsset}
            src="/images/generated/aohys-architecture-proof-surface.png"
            alt={locale === "es" ? "Mapa visual del sistema público, privado y observable de AOHYS" : "Visual map of the AOHYS public, private, and observable system"}
            loading="eager"
            decoding="async"
          />
          <div class={ui.heroProofShots} aria-hidden="true">
            {homeContent.selectedOutcomes.slice(0, 3).map((outcome) => {
              const evidenceImage = evidenceImageForPath(outcome.path);
              const imageSrc = evidenceImage?.thumbSrc ?? evidenceImage?.src ?? outcome.evidence.src;

              return imageSrc ? (
                <span class={ui.heroProofFrame}>
                  <img
                    class={proofImageClass(evidenceImage?.kind ?? "site")}
                    src={imageSrc}
                    alt=""
                    loading="eager"
                    decoding="async"
                  />
                </span>
              ) : null;
            })}
          </div>
          <figcaption class={ui.proofBoardCaption}>
            <span>{copy.publicSample}</span>
            <strong>{homeContent.proofBoardTitle}</strong>
            <p>{homeContent.proofBoardBody}</p>
          </figcaption>
          <div class={ui.heroProofRibbon} aria-label={homeContent.selectedOutcomesHeading}>
            {homeContent.selectedOutcomes.slice(0, 3).map((outcome) => (
              <a class={ui.heroProofRibbonItem} href={outcome.path}>
                <span>{outcome.label}</span>
                <strong>{outcome.title}</strong>
              </a>
            ))}
          </div>
        </figure>
      </section>

      <section class={ui.selectedOutcomes} aria-labelledby="ledger-title" data-home-section="selected-outcomes">
        <div class={ui.sectionHeading}>
          <p class={ui.signalLine}>{copy.proofHeadingSignal}</p>
          <h2 id="ledger-title">{homeContent.selectedOutcomesHeading}</h2>
          <p class={ui.sectionIntro}>{homeContent.selectedOutcomesIntro}</p>
        </div>
        <div class={ui.outcomeLedger}>
          {homeContent.selectedOutcomes.map((outcome, index) => (
            <a class={ui.outcomeRow} href={outcome.path}>
              <span class={ui.outcomeIndex}>{String(index + 1).padStart(2, "0")}</span>
              {(() => {
                const evidenceImage = evidenceImageForPath(outcome.path);
                const imageSrc = evidenceImage?.thumbSrc ?? evidenceImage?.src ?? outcome.evidence.src;
                const imageAlt = imageSrc === outcome.evidence.src
                  ? outcome.evidence.altText
                  : evidenceImage?.alt ?? outcome.evidence.altText;

                return (
                  <figure class={ui.outcomeShot} aria-label={imageAlt}>
                    {imageSrc ? (
                      <img class={screenshotImageClass(evidenceImage?.kind ?? "site")} src={imageSrc} alt={imageAlt} loading="eager" decoding="async" />
                    ) : (
                      <span class={ui.evidenceFallback}>{outcome.evidence.label}</span>
                    )}
                  </figure>
                );
              })()}
              <div class={ui.outcomeSummary}>
                <span class={ui.eyebrow}>{outcome.label}</span>
                <strong class={ui.outcomeTitle}>{outcome.title}</strong>
                <p class={ui.bodyMutedPretty}>{outcome.outcome}</p>
              </div>
              <p class={ui.bodyMutedPretty}>{outcome.role}</p>
              <span class={ui.outcomeArrow} aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>

      <section class={ui.architectureStage} aria-labelledby="home-architecture-title" data-home-section="architecture">
        <div class="min-w-0">
          <h2 id="home-architecture-title">{homeContent.architectureHeading}</h2>
          <p class={ui.architectureLead}>{homeContent.architectureBody}</p>
        </div>
        <div class={ui.architectureProofStack}>
          <figure class={cx(ui.framedImage, "rounded-lg")}>
            <img
              class="w-full aspect-[16/10] object-cover object-center"
              src="/images/generated/aohys-architecture-proof-surface.png"
              alt={locale === "es" ? "Mapa del sistema público y privado de AOHYS" : "AOHYS public and private system map"}
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class={ui.architectureTrack} aria-label={homeContent.architectureHeading}>
            {homeContent.architectureStages.map((stage) => (
              <div class={ui.architectureStep}>
                <span>{stage.label}</span>
                <p>{stage.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class={ui.practiceSection} aria-labelledby="practice-title" data-home-section="practice">
        <div class={ui.sectionHeading}>
          <h2 id="practice-title">{homeContent.practiceHeading}</h2>
          <p class={ui.sectionIntro}>{homeContent.practiceBody}</p>
        </div>
        <div class={ui.practiceList}>
          {homeContent.practicePoints.map((point) => (
            <div class={ui.practiceItem}>
              <span>{point.label}</span>
              <p>{point.text}</p>
            </div>
          ))}
        </div>
      </section>

      <section class={ui.contactBand} aria-labelledby="home-contact-title" data-home-section="contact">
        <div>
          <h2 id="home-contact-title">{homeContent.contactHeading}</h2>
          <p>{homeContent.contactBody}</p>
        </div>
        <div class={ui.contactActions} aria-label={copy.actions}>
          <a class={cx(ui.button, ui.buttonPrimary)} href={homeContent.emailHref}>{homeContent.emailLabel}</a>
          <a class={cx(ui.button, ui.buttonWhatsapp)} href={homeContent.whatsappHref} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="home_contact_band">{homeContent.whatsappLabel}</a>
        </div>
      </section>
    </>
  ) : isArchitecture && architectureContent ? (
    <>
      <section class={ui.architecturePageHero} aria-labelledby="architecture-title" data-architecture-content-id={id}>
        <div class={ui.architecturePageCopy}>
          <p class={cx(ui.signalLine, "!text-[color:var(--color-dark-muted)]")}>{routeSignal}</p>
          <h1 id="architecture-title">{architectureContent.heading}</h1>
          <p class={cx(ui.heroLead, "!text-[color:var(--color-dark-muted)]")}>{architectureContent.deck}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnDark)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <div class={ui.architectureHeroAside}>
          <figure class={ui.darkPanelFigure}>
            <img
              class="w-full aspect-video object-cover object-center"
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Mapa de arquitectura de la muestra pública AOHYS" : "Architecture map for the AOHYS public sample"}
              loading="eager"
              decoding="async"
            />
          </figure>
          <aside class={cx(ui.sourceIndex, ui.sourceIndexDark)} aria-label={architectureContent.sourceLabel}>
            <strong>{architectureContent.sourceLabel}</strong>
            <div class={cx(ui.sourceLinks, ui.sourceLinksDark)}>
              {architectureContent.sourceLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <section class={ui.architectureMap} aria-labelledby="architecture-map-title">
        <div class={ui.sectionHeading}>
          <h2 id="architecture-map-title">{variant.title}</h2>
          <p class={ui.sectionIntro}>{variant.summary}</p>
        </div>
        <div class={ui.rowList}>
          {architectureContent.sections.map((section) => (
            <article class={ui.architectureRow}>
              <h3>{section.title}</h3>
              <p>{section.body}</p>
              {section.links && (
                <div class={cx(ui.sourceLinks, ui.sourceLinksInline)}>
                  {section.links.map((link) => (
                    <a href={link.href}>{link.label}</a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class={ui.boundaryNote} aria-label={architectureContent.heading}>
        <p>{architectureContent.boundaryNote}</p>
      </section>
    </>
  ) : isCaseStudyIndex && caseStudyIndexContent ? (
    <>
      <section class={ui.caseStudyIndexHero} aria-labelledby="case-study-index-title" data-case-study-index-content-id={id}>
        <div class={ui.caseStudyHeroCopy}>
          <p class={ui.signalLine}>{routeSignal}</p>
          <h1 id="case-study-index-title">{caseStudyIndexContent.heading}</h1>
          <p class={ui.heroLead}>{caseStudyIndexContent.intro}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnLightHero)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <figure class={ui.caseIndexProofWall} aria-label={locale === "es" ? "Capturas públicas de proyectos seleccionados" : "Public screenshots from selected work"}>
          <span class={ui.caseIndexProofFrame}>
            <img class={screenshotImageClass("site")} src="/images/proof/casa-roca-production.png" alt={locale === "es" ? "Captura pública de Casa Roca" : "Public Casa Roca screenshot"} loading="eager" decoding="async" />
          </span>
          <span class={ui.caseIndexProofFrame}>
            <img class={screenshotImageClass("landing")} src="/images/proof/barber-central-proof-thumb.png" alt={locale === "es" ? "Landing page de The Barber Central" : "The Barber Central landing page"} loading="eager" decoding="async" />
          </span>
          <span class={ui.caseIndexProofFrame}>
            <img class={screenshotImageClass("dashboard")} src="/images/proof/nutri-plan-proof-thumb.png" alt={locale === "es" ? "Dashboard administrativo de Nutri Plan" : "Nutri Plan administrative dashboard"} loading="eager" decoding="async" />
          </span>
        </figure>
      </section>

      <section class={ui.contentSection} aria-labelledby="selected-work-title">
        <div class={ui.sectionHeading}>
          <h2 id="selected-work-title">{caseStudyIndexContent.heading}</h2>
          <p class={ui.sectionIntro}>{caseStudyIndexContent.intro}</p>
        </div>
        <div class={ui.rowList}>
          {caseStudyIndexContent.entries.map((entry) => (
            <a class={ui.selectedWorkRow} href={entry.path}>
              <span>{entry.statusLabel}</span>
              <figure class={ui.selectedWorkShot}>
                {(() => {
                  const evidenceImage = evidenceImageForPath(entry.path);
                  return evidenceImage ? (
                    <img
                      class={screenshotImageClass(evidenceImage.kind, "compact")}
                      src={evidenceImage.thumbSrc ?? evidenceImage.src}
                      alt={evidenceImage.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span>{entry.evidenceLabel}</span>
                  );
                })()}
              </figure>
              <strong class={ui.selectedWorkTitle}>{entry.title}</strong>
              <p>{entry.summary}</p>
              <em>{entry.evidenceLabel}</em>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : isCaseStudy && caseStudyContent ? (
    <>
      <section class={ui.caseStudyHero} aria-labelledby="case-study-title" data-case-study-content-id={id}>
        <div class={ui.caseStudyHeroCopy}>
          <p class={ui.signalLine}>{caseStudyContent.statusLabel}</p>
          <h1 id="case-study-title">{variant.title}</h1>
          <p class={ui.heroLead}>{caseStudyContent.overview}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnLightHero)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <aside class={ui.caseStudyStatus} aria-label={caseStudyContent.statusLabel}>
          {caseStudyEvidenceImage && (
            <img
              src={caseStudyEvidenceImage.src}
              alt={caseStudyEvidenceImage.alt}
              loading="eager"
              decoding="async"
            />
          )}
          <span>{caseStudyContent.statusLabel}</span>
          <strong>{variant.summary}</strong>
        </aside>
      </section>

      <section class={ui.contentSection} aria-labelledby="case-study-detail-title">
        <div class={ui.sectionHeading}>
          <h2 id="case-study-detail-title">{variant.title}</h2>
          <p class={ui.sectionIntro}>{variant.summary}</p>
        </div>
        <div class={ui.rowList}>
          {caseStudySections.map((section) => (
            <article class={ui.studyRow}>
              <h3>{section.title}</h3>
              <p>{section.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="case-study-evidence-title">
        <div class={ui.sectionHeading}>
          <h2 id="case-study-evidence-title">{caseStudyContent.publicEvidenceTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {caseStudyContent.publicEvidence.map((evidence) => (
            <a
              class={ui.evidenceLink}
              href={evidence.href}
              aria-label={evidence.altText}
              target={evidence.href.startsWith("http") ? "_blank" : undefined}
              rel={evidence.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <span>{evidence.label}</span>
              <strong>{evidence.description}</strong>
            </a>
          ))}
        </div>
      </section>

      <section class={ui.confidentiality} aria-labelledby="case-study-confidentiality-title">
        <h2 id="case-study-confidentiality-title">{caseStudyContent.confidentialityNote.title}</h2>
        <p>{caseStudyContent.confidentialityNote.body}</p>
      </section>
    </>
  ) : isResume && resumeContent ? (
    <>
      <section class={ui.resumeHero} aria-labelledby="resume-title" data-resume-content-id={id}>
        <div class={ui.resumeIdentity}>
          <p class={cx(ui.signalLine, "!text-[color:var(--color-dark-honey)]")}>{routeSignal}</p>
          <h1 id="resume-title">{resumeContent.name}</h1>
          <p class={ui.resumeRole}>{resumeContent.role}</p>
          <p class={cx(ui.heroLead, "max-w-[52ch] !text-[color:var(--color-dark-muted)]")}>{resumeContent.intro}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            <a class={cx(ui.button, ui.buttonPrimary)} href={resumeContent.pdf.href} download={resumeContent.pdf.fileName}>
              {resumeContent.pdf.label}
            </a>
            {primaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnDark)} href={primaryHref}>{variant.primaryActionLabel}</a>}
          </div>
        </div>

        <aside class={ui.resumeProofPanel} aria-label={resumeContent.proof.label}>
          <figure class={ui.darkPanelFigure}>
            <img
              class="w-full aspect-[16/10] object-cover object-center"
              src="/images/generated/aohys-delivery-artifact.png"
              alt={locale === "es" ? "Artefacto visual de entrega, QA y release de AOHYS" : "Visual artifact of AOHYS delivery, QA, and release practice"}
              loading="eager"
              decoding="async"
            />
          </figure>
          <div class={ui.resumeProofCopy}>
            <span>{resumeContent.proof.label}</span>
            <strong>{resumeContent.proof.title}</strong>
            <p>{resumeContent.proof.body}</p>
          </div>
          <div class={ui.resumeContact} aria-label={resumeContent.name}>
            <span>{resumeContent.location}</span>
            {resumeContent.contactLinks.map((link) => (
              <a href={link.href}>
                <strong>{link.label}</strong>
                <span>{link.text}</span>
              </a>
            ))}
          </div>
        </aside>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-summary-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-summary-title">{resumeContent.summaryTitle}</h2>
        </div>
        <div class={ui.resumeCopy}>
          {resumeContent.summary.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-highlights-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-highlights-title">{resumeContent.highlightsTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {resumeContent.highlights.map((highlight) => (
            <article class={ui.resumeRow}>
              <span>{highlight.label}</span>
              <p>{highlight.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-projects-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-projects-title">{resumeContent.projectsTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {resumeContent.projects.map((project) => (
            <article class={ui.resumeEntry}>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <ul>
                {project.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-experience-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-experience-title">{resumeContent.experienceTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {resumeContent.experience.map((job) => (
            <article class={ui.resumeEntry}>
              <div class={ui.resumeEntryHeading}>
                <h3>{job.role}</h3>
                <span>{job.period}</span>
              </div>
              <p>{job.company}</p>
              <ul>
                {job.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-skills-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-skills-title">{resumeContent.skillsTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {resumeContent.skills.map((skillGroup) => (
            <article class={ui.resumeRow}>
              <span>{skillGroup.label}</span>
              <p>{skillGroup.items.join(", ")}</p>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-education-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-education-title">{resumeContent.educationTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {resumeContent.education.map((education) => (
            <article class={ui.resumeRow}>
              <span>{education.period}</span>
              <p><strong>{education.degree}</strong> · {education.institution}</p>
            </article>
          ))}
          <article class={ui.resumeRow}>
            <span>{resumeContent.languagesTitle}</span>
            <p>{resumeContent.languages.join(", ")}</p>
          </article>
        </div>
      </section>

      <section class={ui.contentSection} aria-labelledby="resume-context-title">
        <div class={ui.sectionHeading}>
          <h2 id="resume-context-title">{resumeContent.contextTitle}</h2>
          <p class={ui.sectionIntro}>{resumeContent.pdf.description}</p>
        </div>
        <div class={ui.rowList}>
          {resumeContent.contextLinks.map((link) => (
            <a class={ui.evidenceLink} href={link.href}>
              <span>{link.label}</span>
              <strong>{link.text}</strong>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : isContact ? (
    <>
      <section class={ui.contactFormSection} aria-labelledby="contact-title" data-contact-content-id={id}>
        <div class={ui.contactFormCopy}>
          <p class={cx(ui.signalLine, "!text-[color:var(--color-dark-honey)]")}>{routeSignal}</p>
          <h1 id="contact-title">{variant.title}</h1>
          <p class={cx(ui.heroLead, "max-w-[50ch] !text-[color:var(--color-dark-muted)]")}>{variant.summary}</p>
          <div class={ui.contactDirectActions} aria-label={copy.actions}>
            <a class={cx(ui.button, ui.buttonWhatsapp)} href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_hero">{contactCopy.whatsappLabel}</a>
            <a class={cx(ui.button, ui.buttonSecondaryOnDark)} href={directEmailHref} data-analytics-event="email_cta_clicked" data-analytics-target="contact_hero">{contactCopy.emailLabel}</a>
          </div>
          <figure class={ui.contactArchitectureCard}>
            <img
              class="w-full aspect-video object-cover object-center"
              src="/images/generated/aohys-hero-system-map.png"
              alt={locale === "es" ? "Mapa visual del flujo de contacto y operación de AOHYS" : "Visual map of the AOHYS contact and operations flow"}
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <form
          class={ui.contactForm}
          method="post"
          action={contactEndpoint || directEmailHref}
          data-contact-form
          data-contact-endpoint={contactEndpoint}
          data-success-message={contactCopy.successMessage}
          data-degraded-success-message={contactCopy.degradedSuccessMessage}
          data-error-message={contactCopy.errorMessage}
          data-validation-message={contactCopy.validationMessage}
          data-email-error-message={contactCopy.emailErrorMessage}
          data-backend-error-message={contactCopy.backendErrorMessage}
          data-endpoint-missing={contactCopy.endpointMissing}
          data-retry-label={contactCopy.retryLabel}
          data-analytics-view="contact_form_viewed"
          data-analytics-submit="contact_form_submit_attempted"
          data-analytics-target="contact_form"
        >
          <div class={ui.contactFormHeading}>
            <h2>{contactCopy.formTitle}</h2>
            <p>{contactCopy.formIntro}</p>
          </div>

          <label class={ui.fieldLabel}>
            <span>{contactCopy.nameLabel}</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>

          <div class={ui.fieldGrid}>
            <label class={ui.fieldLabel}>
              <span>{contactCopy.emailLabel}</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>
            <label class={ui.fieldLabel}>
              <span>{contactCopy.phoneLabel}</span>
              <input name="phone" type="tel" autocomplete="tel" />
            </label>
          </div>

          <label class={ui.fieldLabel}>
            <span>{contactCopy.companyLabel}</span>
            <input name="company" type="text" autocomplete="organization" />
          </label>

          <div class={ui.fieldGrid}>
            <label class={ui.fieldLabel}>
              <span>{contactCopy.intentLabel}</span>
              <select name="intent" required>
                <option value="project">{contactCopy.intentProject}</option>
                <option value="hiring">{contactCopy.intentHiring}</option>
                <option value="architecture-review">{contactCopy.intentArchitecture}</option>
                <option value="website">{contactCopy.intentWebsite}</option>
                <option value="other">{contactCopy.intentOther}</option>
              </select>
            </label>

            <fieldset class={ui.contactChoice}>
              <legend>{contactCopy.preferredContactLabel}</legend>
              <label>
                <input name="preferredContactPath" type="radio" value="email" required checked />
                <span>{contactCopy.preferredEmail}</span>
              </label>
              <label>
                <input name="preferredContactPath" type="radio" value="whatsapp" required />
                <span>{contactCopy.preferredWhatsApp}</span>
              </label>
            </fieldset>
          </div>

          <label class={ui.fieldLabel}>
            <span>{contactCopy.messageLabel}</span>
            <textarea name="message" rows="6" required></textarea>
          </label>

          <label class={ui.consentRow}>
            <input name="consentToContact" type="checkbox" value="true" required />
            <span>{contactCopy.consentLabel}</span>
          </label>

          <label class={ui.contactHoneypot} aria-hidden="true">
            <span>Website</span>
            <input name="website" type="text" autocomplete="off" tabindex="-1" />
          </label>
          <input name="formStartedAt" type="hidden" value="" />
          <input name="sourcePath" type="hidden" value={route.path} />
          <input name="locale" type="hidden" value={locale} />
          <input name="referrer" type="hidden" value="" />

          <div class={ui.contactSubmitRow}>
            <button class={cx(ui.button, ui.buttonPrimary)} type="submit" data-submit-label={contactCopy.submitLabel} data-sending-label={contactCopy.sendingLabel}>
              {contactCopy.submitLabel}
            </button>
            <p>{contactCopy.fallbackText} <a href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_form_fallback">{contactCopy.whatsappLabel}</a></p>
          </div>
          <p class={ui.contactStatus} role="status" data-contact-status></p>
        </form>
      </section>

      <script>
        const dispatchContactAnalytics = (event: string, properties: Record<string, string | boolean> = {}) => {
          window.dispatchEvent(new CustomEvent("aohys:analytics", {
            detail: { event, properties },
          }));
        };

        const messageWithRetry = (message: string | undefined, retryLabel: string | undefined) =>
          [message, retryLabel].filter(Boolean).join(" ");

        const readErrorCode = async (response: Response) => {
          try {
            const payload = await response.json();
            return typeof payload?.code === "string" ? payload.code : "";
          } catch {
            return "";
          }
        };

        const readSubmissionResult = async (response: Response) => {
          try {
            return await response.json();
          } catch {
            return {};
          }
        };

        const stringStatus = (payload: unknown, key: string, fallback: string) => {
          if (!payload || typeof payload !== "object") {
            return fallback;
          }

          const value = (payload as Record<string, unknown>)[key];
          return typeof value === "string" && value ? value : fallback;
        };

        const shouldShowDegradedSuccess = (notificationStatus: string) =>
          notificationStatus === "failed" || notificationStatus === "skipped";

        const failureReasonForResponse = (response: Response, code: string) => {
          if (response.status === 400 || code === "validation_error") {
            return "validation_failed";
          }

          if (
            code === "email_delivery_failed" ||
            code === "provider_configuration_error" ||
            code === "analytics_delivery_failed"
          ) {
            return "email_delivery_failed";
          }

          return "backend_unavailable";
        };

        const failureMessageForReason = (form: HTMLFormElement, reason: string) => {
          if (reason === "validation_failed") {
            return form.dataset.validationMessage ?? form.dataset.errorMessage ?? "";
          }

          if (reason === "email_delivery_failed") {
            return form.dataset.emailErrorMessage ?? form.dataset.errorMessage ?? "";
          }

          return form.dataset.backendErrorMessage ?? form.dataset.errorMessage ?? "";
        };

        for (const form of document.querySelectorAll("[data-contact-form]")) {
          const endpoint = form instanceof HTMLFormElement ? form.dataset.contactEndpoint : "";
          const status = form.querySelector("[data-contact-status]");
          const startedAt = form.querySelector('input[name="formStartedAt"]');
          const referrer = form.querySelector('input[name="referrer"]');
          const submitButton = form.querySelector('button[type="submit"]');

          if (startedAt instanceof HTMLInputElement) {
            startedAt.value = String(Date.now());
          }

          if (referrer instanceof HTMLInputElement) {
            referrer.value = document.referrer;
          }

          form.addEventListener("submit", async (event) => {
            event.preventDefault();

            if (!(form instanceof HTMLFormElement)) {
              return;
            }

            if (!form.checkValidity()) {
              if (status instanceof HTMLElement) {
                status.dataset.state = "error";
                status.textContent = messageWithRetry(
                  form.dataset.validationMessage,
                  form.dataset.retryLabel,
                );
              }
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "validation_failed",
              });
              form.reportValidity();
              return;
            }

            if (!endpoint) {
              if (status instanceof HTMLElement) {
                status.dataset.state = "error";
                status.textContent = messageWithRetry(
                  form.dataset.endpointMissing,
                  form.dataset.retryLabel,
                );
              }
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "endpoint_missing",
              });
              return;
            }

            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());
            payload.consentToContact = formData.get("consentToContact") === "true" ? "true" : "";

            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = true;
              submitButton.textContent = submitButton.dataset.sendingLabel ?? submitButton.textContent;
            }
            if (status instanceof HTMLElement) {
              status.dataset.state = "sending";
              status.textContent = "";
            }

            try {
              const response = await fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  ...payload,
                  consentToContact: payload.consentToContact === "true",
                  formStartedAt: Number(payload.formStartedAt),
                }),
              });

              if (!response.ok) {
                const errorCode = await readErrorCode(response);
                const failureReason = failureReasonForResponse(response, errorCode);
                dispatchContactAnalytics("contact_form_submit_failed", {
                  failure_reason: failureReason,
                });
                if (status instanceof HTMLElement) {
                  status.dataset.state = "error";
                  status.textContent = messageWithRetry(
                    failureMessageForReason(form, failureReason),
                    form.dataset.retryLabel,
                  );
                }
                return;
              }

              const result = await readSubmissionResult(response);
              const notificationStatus = stringStatus(result, "notificationStatus", "unknown");
              const analyticsStatus = stringStatus(result, "analyticsStatus", "unknown");
              const deliveryDegraded = shouldShowDegradedSuccess(notificationStatus);

              dispatchContactAnalytics("contact_form_submit_succeeded", {
                notification_status: notificationStatus,
                analytics_status: analyticsStatus,
                delivery_degraded: deliveryDegraded,
              });

              form.reset();
              if (status instanceof HTMLElement) {
                status.dataset.state = deliveryDegraded ? "warning" : "success";
                status.textContent = deliveryDegraded
                  ? form.dataset.degradedSuccessMessage ?? form.dataset.successMessage ?? ""
                  : form.dataset.successMessage ?? "";
              }
            } catch {
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "backend_unavailable",
              });
              if (status instanceof HTMLElement) {
                status.dataset.state = "error";
                status.textContent = messageWithRetry(
                  form.dataset.backendErrorMessage ?? form.dataset.errorMessage,
                  form.dataset.retryLabel,
                );
              }
            } finally {
              if (submitButton instanceof HTMLButtonElement) {
                submitButton.disabled = false;
                submitButton.textContent = submitButton.dataset.submitLabel ?? submitButton.textContent;
              }
            }
          });
        }
      </script>
    </>
  ) : isPrivacy && privacyContent ? (
    <>
      <section class={ui.routeHero} aria-labelledby="privacy-title" data-privacy-content-id={id}>
        <div class={ui.routeHeroCopy}>
          <p class={ui.signalLine}>{routeSignal}</p>
          <h1 id="privacy-title">{privacyContent.heading}</h1>
          <p class={ui.heroLead}>{privacyContent.intro}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondary)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <aside class={ui.routePanel} aria-label={copy.routeMetadataAria}>
          <span>{copy.canonical}</span>
          <strong>{route.path}</strong>
          <span>{copy.contentType}</span>
          <strong>{node.type}</strong>
        </aside>
      </section>

      <section class={ui.routeProofSection} aria-labelledby="privacy-sections-title">
        <div class={ui.sectionHeading}>
          <h2 id="privacy-sections-title">{variant.summary}</h2>
        </div>
        <div class={ui.rowList}>
          {privacyContent.sections.map((section) => (
            <div class={ui.routeProofItem}>
              <span>{section.title}</span>
              <p>{section.body}</p>
            </div>
          ))}
        </div>
        <p class={ui.privacyBoundaryNote}>{privacyContent.boundaryNote}</p>
      </section>
    </>
  ) : (
    <>
      <section class={ui.routeHero} aria-labelledby="route-title" data-content-type={node.type}>
        <div class={ui.routeHeroCopy}>
          <p class={ui.signalLine}>{routeSignal}</p>
          <h1 id="route-title">{variant.title}</h1>
          <p class={ui.heroLead}>{variant.summary}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondary)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <aside class={ui.routePanel} aria-label={copy.routeMetadataAria}>
          <span>{copy.canonical}</span>
          <strong>{route.path}</strong>
          <span>{copy.contentType}</span>
          <strong>{node.type}</strong>
        </aside>
      </section>

      <section class={ui.routeProofSection} aria-labelledby="route-proof-title">
        <div class={ui.sectionHeading}>
          <h2 id="route-proof-title">{copy.routeProofTitle}</h2>
        </div>
        <div class={ui.rowList}>
          {copy.routeProof.map((item) => (
            <div class={ui.routeProofItem}>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>
    </>
  )
}
