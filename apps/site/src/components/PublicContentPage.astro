---
import {
  getArchitecturePageContent,
  getCaseStudyIndexContent,
  getCaseStudyPageContent,
  getHomePageContent,
  getLocalizedPath,
  getPrivacyPageContent,
  getResumePageContent,
  type ContentId,
  type PublicRoute,
} from "@aohys/content-graph";
import { getUiCopy } from "../i18n";

interface Props {
  route: PublicRoute;
}

const { route } = Astro.props;
const { id, locale, node, variant } = route;
const isHome = id === "home";
const isArchitecture = id === "architecture";
const isCaseStudyIndex = node.type === "case-study-index";
const isCaseStudy = node.type === "case-study";
const isResume = node.type === "resume";
const isContact = node.type === "contact";
const isPrivacy = node.type === "privacy";
const copy = getUiCopy(locale).publicPage;
const contactCopy = getUiCopy(locale).contactForm;
const homeContent = isHome ? getHomePageContent(locale) : undefined;
const architectureContent = isArchitecture ? getArchitecturePageContent(locale) : undefined;
const caseStudyIndexContent = isCaseStudyIndex ? getCaseStudyIndexContent(locale) : undefined;
const caseStudyContent = isCaseStudy ? getCaseStudyPageContent(id, locale) : undefined;
const resumeContent = isResume ? getResumePageContent(locale) : undefined;
const privacyContent = isPrivacy ? getPrivacyPageContent(locale) : undefined;
const caseStudySections = caseStudyContent ? [
  caseStudyContent.problem,
  caseStudyContent.businessOutcome,
  caseStudyContent.role,
  caseStudyContent.constraints,
  caseStudyContent.architectureDecisions,
  caseStudyContent.executionHighlights,
  caseStudyContent.qualitySecurityPerformance,
] : [];

function actionHref(contentId?: ContentId): string | undefined {
  return contentId ? getLocalizedPath(contentId, locale) : undefined;
}

const primaryHref = actionHref(variant.primaryActionContentId);
const secondaryHref = actionHref(variant.secondaryActionContentId);
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";
const publicContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "alejandro.ortiz@aohys.com";
const publicWhatsAppUrl = import.meta.env.PUBLIC_WHATSAPP_URL ?? "https://wa.me/522299020825";
const directEmailHref = `mailto:${publicContactEmail}`;

function splitHeadline(headline: string): string[] {
  const parts = headline.split(". ");
  return parts.map((part, index) => {
    if (index < parts.length - 1 && !part.endsWith(".")) {
      return `${part}.`;
    }

    return part;
  });
}

const homeHeadlineParts = homeContent ? splitHeadline(homeContent.headline) : [];

const routeSignalById: Partial<Record<ContentId | string, string>> = {
  "case-studies": locale === "es" ? "Trabajo que puedo mostrar" : "Work I can show",
  architecture: locale === "es" ? "Sistema público" : "Public system",
  resume: locale === "es" ? "Contexto profesional" : "Professional context",
  contact: locale === "es" ? "Contacto directo" : "Direct contact",
  privacy: locale === "es" ? "Límite de privacidad" : "Privacy boundary",
  practice: locale === "es" ? "Práctica de ingeniería" : "Engineering practice",
};
const routeSignal = routeSignalById[id] ?? variant.summary;

const evidenceImageByContentId: Partial<Record<ContentId | string, { src: string; alt: string }>> = {
  "case-study:casa-roca": {
    src: "/images/proof/casa-roca-production.png",
    alt: locale === "es" ? "Captura pública del sitio Casa Roca en producción" : "Public Casa Roca production website screenshot",
  },
  "case-study:the-barber-central": {
    src: "/images/proof/barber-central-ops.png",
    alt: locale === "es" ? "Captura sanitizada de operaciones de The Barber Central" : "Sanitized The Barber Central operations screenshot",
  },
  "case-study:nutri-plan": {
    src: "/images/proof/nutri-plan-proof.png",
    alt: locale === "es" ? "Captura sanitizada de Nutri Plan" : "Sanitized Nutri Plan screenshot",
  },
  "case-study:engineering-practice": {
    src: "/images/proof/aohys-system-map.svg",
    alt: locale === "es" ? "Mapa de arquitectura pública de AOHYS" : "AOHYS public architecture map",
  },
};

function evidenceImageForContent(contentId: string) {
  return evidenceImageByContentId[contentId];
}

function evidenceImageForPath(path: string) {
  if (path.includes("casa-roca")) {
    return evidenceImageForContent("case-study:casa-roca");
  }

  if (path.includes("the-barber-central")) {
    return evidenceImageForContent("case-study:the-barber-central");
  }

  if (path.includes("nutri-plan")) {
    return evidenceImageForContent("case-study:nutri-plan");
  }

  if (
    path.includes("engineering-practice") ||
    path.includes("practica-de-ingenieria") ||
    path === "/practice" ||
    path === "/es/practica"
  ) {
    return evidenceImageForContent("case-study:engineering-practice");
  }

  return undefined;
}

const caseStudyEvidenceImage = isCaseStudy ? evidenceImageForContent(id) : undefined;
---

{
  isHome && homeContent ? (
    <>
      <section class="hero-section home-proof-hero" aria-labelledby="home-title" data-home-content-id={id}>
        <div class="hero-copy">
          <p class="signal-line">{copy.signal}</p>
          <h1 id="home-title" class="home-headline" aria-label={homeContent.headline}>
            {homeHeadlineParts.map((part) => <span aria-hidden="true">{part}</span>)}
          </h1>
          <p class="hero-lead">
            {homeContent.deck}
          </p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <figure class="evidence-table" aria-label={homeContent.proofBoardLabel}>
          <figcaption class="evidence-table-caption">
            <span>{copy.publicSample}</span>
            <strong>{homeContent.proofBoardTitle}</strong>
            <p>{homeContent.proofBoardBody}</p>
          </figcaption>
          <div class="evidence-shot evidence-shot-primary">
            <img
              src="/images/proof/casa-roca-production.png"
              alt={locale === "es" ? "Captura pública de Casa Roca en producción" : "Public Casa Roca production screenshot"}
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="evidence-shot evidence-shot-secondary">
            <img
              src="/images/proof/barber-central-ops.png"
              alt={locale === "es" ? "Captura sanitizada de The Barber Central" : "Sanitized The Barber Central screenshot"}
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="evidence-shot evidence-shot-tertiary">
            <img
              src="/images/proof/nutri-plan-proof.png"
              alt={locale === "es" ? "Captura sanitizada de Nutri Plan" : "Sanitized Nutri Plan screenshot"}
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="evidence-system-map" aria-hidden="true">
            <img src="/images/proof/aohys-system-map.svg" alt="" loading="eager" decoding="async" />
          </div>
        </figure>
      </section>

      <section class="ledger-section selected-outcomes" aria-labelledby="ledger-title" data-home-section="selected-outcomes">
        <div class="section-heading">
          <p class="signal-line">{copy.proofHeadingSignal}</p>
          <h2 id="ledger-title">{homeContent.selectedOutcomesHeading}</h2>
          <p class="section-intro">{homeContent.selectedOutcomesIntro}</p>
        </div>
        <div class="outcome-ledger">
          {homeContent.selectedOutcomes.map((outcome, index) => (
            <a class="outcome-row" href={outcome.path}>
              <span class="outcome-index">{String(index + 1).padStart(2, "0")}</span>
              <figure class="outcome-shot" aria-label={outcome.evidence.altText}>
                {outcome.evidence.src ? (
                  <img src={outcome.evidence.src} alt={outcome.evidence.altText} loading="eager" decoding="async" />
                ) : (
                  <span class="evidence-fallback">{outcome.evidence.label}</span>
                )}
              </figure>
              <div class="outcome-summary">
                <span class="outcome-label">{outcome.label}</span>
                <strong>{outcome.title}</strong>
                <p>{outcome.outcome}</p>
              </div>
              <p class="outcome-scope">{outcome.role}</p>
              <span class="outcome-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>

      <section class="architecture-stage" aria-labelledby="home-architecture-title" data-home-section="architecture">
        <div class="architecture-copy">
          <h2 id="home-architecture-title">{homeContent.architectureHeading}</h2>
          <p>{homeContent.architectureBody}</p>
        </div>
        <div class="architecture-proof-stack">
          <figure class="architecture-proof-visual">
            <img
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Mapa del sistema público y privado de AOHYS" : "AOHYS public and private system map"}
              loading="lazy"
              decoding="async"
            />
          </figure>
          <div class="architecture-track" aria-label={homeContent.architectureHeading}>
            {homeContent.architectureStages.map((stage) => (
              <div class="architecture-step">
                <span>{stage.label}</span>
                <p>{stage.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="practice-section" aria-labelledby="practice-title" data-home-section="practice">
        <div class="section-heading">
          <h2 id="practice-title">{homeContent.practiceHeading}</h2>
          <p class="section-intro">{homeContent.practiceBody}</p>
        </div>
        <div class="practice-list">
          {homeContent.practicePoints.map((point) => (
            <div class="practice-item">
              <span>{point.label}</span>
              <p>{point.text}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="contact-band" aria-labelledby="home-contact-title" data-home-section="contact">
        <div>
          <h2 id="home-contact-title">{homeContent.contactHeading}</h2>
          <p>{homeContent.contactBody}</p>
        </div>
        <div class="contact-actions" aria-label={copy.actions}>
          <a class="button button-primary" href={homeContent.emailHref}>{homeContent.emailLabel}</a>
          <a class="button button-whatsapp" href={homeContent.whatsappHref} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="home_contact_band">{homeContent.whatsappLabel}</a>
        </div>
      </section>
    </>
  ) : isArchitecture && architectureContent ? (
    <>
      <section class="architecture-page-hero" aria-labelledby="architecture-title" data-architecture-content-id={id}>
        <div class="architecture-page-copy">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="architecture-title">{architectureContent.heading}</h1>
          <p class="hero-lead">{architectureContent.deck}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <div class="architecture-hero-aside">
          <figure class="architecture-hero-map">
            <img
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Mapa de arquitectura de la muestra pública AOHYS" : "Architecture map for the AOHYS public sample"}
              loading="eager"
              decoding="async"
            />
          </figure>
          <aside class="source-index" aria-label={architectureContent.sourceLabel}>
            <strong>{architectureContent.sourceLabel}</strong>
            <div class="source-links">
              {architectureContent.sourceLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <section class="architecture-map" aria-labelledby="architecture-map-title">
        <div class="section-heading">
          <h2 id="architecture-map-title">{variant.title}</h2>
          <p class="section-intro">{variant.summary}</p>
        </div>
        <div class="architecture-rows">
          {architectureContent.sections.map((section) => (
            <article class="architecture-row">
              <h3>{section.title}</h3>
              <p>{section.body}</p>
              {section.links && (
                <div class="source-links inline">
                  {section.links.map((link) => (
                    <a href={link.href}>{link.label}</a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="boundary-note" aria-label={architectureContent.heading}>
        <p>{architectureContent.boundaryNote}</p>
      </section>
    </>
  ) : isCaseStudyIndex && caseStudyIndexContent ? (
    <>
      <section class="case-study-index-hero" aria-labelledby="case-study-index-title" data-case-study-index-content-id={id}>
        <div class="case-study-hero-copy">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="case-study-index-title">{caseStudyIndexContent.heading}</h1>
          <p class="hero-lead">{caseStudyIndexContent.intro}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <figure class="case-index-proof-wall" aria-label={locale === "es" ? "Capturas públicas de proyectos seleccionados" : "Public screenshots from selected work"}>
          <img src="/images/proof/casa-roca-production.png" alt={locale === "es" ? "Captura pública de Casa Roca" : "Public Casa Roca screenshot"} loading="eager" decoding="async" />
          <img src="/images/proof/barber-central-ops.png" alt={locale === "es" ? "Captura sanitizada de The Barber Central" : "Sanitized The Barber Central screenshot"} loading="eager" decoding="async" />
          <img src="/images/proof/nutri-plan-proof.png" alt={locale === "es" ? "Captura sanitizada de Nutri Plan" : "Sanitized Nutri Plan screenshot"} loading="eager" decoding="async" />
        </figure>
      </section>

      <section class="selected-work-index" aria-labelledby="selected-work-title">
        <div class="section-heading">
          <h2 id="selected-work-title">{caseStudyIndexContent.heading}</h2>
          <p class="section-intro">{caseStudyIndexContent.intro}</p>
        </div>
        <div class="selected-work-rows">
          {caseStudyIndexContent.entries.map((entry) => (
            <a class="selected-work-row" href={entry.path}>
              <span>{entry.statusLabel}</span>
              <figure class="selected-work-shot">
                {(() => {
                  const evidenceImage = evidenceImageForPath(entry.path);
                  return evidenceImage ? (
                    <img
                      src={evidenceImage.src}
                      alt={evidenceImage.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span>{entry.evidenceLabel}</span>
                  );
                })()}
              </figure>
              <strong>{entry.title}</strong>
              <p>{entry.summary}</p>
              <em>{entry.evidenceLabel}</em>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : isCaseStudy && caseStudyContent ? (
    <>
      <section class="case-study-hero" aria-labelledby="case-study-title" data-case-study-content-id={id}>
        <div class="case-study-hero-copy">
          <p class="signal-line">{caseStudyContent.statusLabel}</p>
          <h1 id="case-study-title">{variant.title}</h1>
          <p class="hero-lead">{caseStudyContent.overview}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <aside class="case-study-status" aria-label={caseStudyContent.statusLabel}>
          {caseStudyEvidenceImage && (
            <img
              src={caseStudyEvidenceImage.src}
              alt={caseStudyEvidenceImage.alt}
              loading="eager"
              decoding="async"
            />
          )}
          <span>{caseStudyContent.statusLabel}</span>
          <strong>{variant.summary}</strong>
        </aside>
      </section>

      <section class="case-study-detail" aria-labelledby="case-study-detail-title">
        <div class="section-heading">
          <h2 id="case-study-detail-title">{variant.title}</h2>
          <p class="section-intro">{variant.summary}</p>
        </div>
        <div class="case-study-rows">
          {caseStudySections.map((section) => (
            <article class="case-study-row">
              <h3>{section.title}</h3>
              <p>{section.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="case-study-evidence" aria-labelledby="case-study-evidence-title">
        <div class="section-heading">
          <h2 id="case-study-evidence-title">{caseStudyContent.publicEvidenceTitle}</h2>
        </div>
        <div class="evidence-list">
          {caseStudyContent.publicEvidence.map((evidence) => (
            <a class="evidence-link" href={evidence.href} aria-label={evidence.altText}>
              <span>{evidence.label}</span>
              <strong>{evidence.description}</strong>
            </a>
          ))}
        </div>
      </section>

      <section class="case-study-confidentiality" aria-labelledby="case-study-confidentiality-title">
        <h2 id="case-study-confidentiality-title">{caseStudyContent.confidentialityNote.title}</h2>
        <p>{caseStudyContent.confidentialityNote.body}</p>
      </section>
    </>
  ) : isResume && resumeContent ? (
    <>
      <section class="resume-hero" aria-labelledby="resume-title" data-resume-content-id={id}>
        <div class="resume-identity">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="resume-title">{resumeContent.name}</h1>
          <p class="resume-role">{resumeContent.role}</p>
          <p class="hero-lead">{resumeContent.intro}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            <a class="button button-primary" href={resumeContent.pdf.href} download={resumeContent.pdf.fileName}>
              {resumeContent.pdf.label}
            </a>
            {primaryHref && <a class="button button-secondary" href={primaryHref}>{variant.primaryActionLabel}</a>}
          </div>
        </div>

        <aside class="resume-proof-panel" aria-label={resumeContent.proof.label}>
          <figure class="resume-proof-visual">
            <img
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Artefacto visual del sistema público, privado y observable de AOHYS" : "Visual artifact of the AOHYS public, private, and observable system"}
              loading="eager"
              decoding="async"
            />
          </figure>
          <div class="resume-proof-copy">
            <span>{resumeContent.proof.label}</span>
            <strong>{resumeContent.proof.title}</strong>
            <p>{resumeContent.proof.body}</p>
          </div>
          <div class="resume-contact" aria-label={resumeContent.name}>
            <span>{resumeContent.location}</span>
            {resumeContent.contactLinks.map((link) => (
              <a href={link.href}>
                <strong>{link.label}</strong>
                <span>{link.text}</span>
              </a>
            ))}
          </div>
        </aside>
      </section>

      <section class="resume-section resume-summary" aria-labelledby="resume-summary-title">
        <div class="section-heading">
          <h2 id="resume-summary-title">{resumeContent.summaryTitle}</h2>
        </div>
        <div class="resume-copy">
          {resumeContent.summary.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section class="resume-section" aria-labelledby="resume-highlights-title">
        <div class="section-heading">
          <h2 id="resume-highlights-title">{resumeContent.highlightsTitle}</h2>
        </div>
        <div class="resume-ledger">
          {resumeContent.highlights.map((highlight) => (
            <article class="resume-row">
              <span>{highlight.label}</span>
              <p>{highlight.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-section" aria-labelledby="resume-projects-title">
        <div class="section-heading">
          <h2 id="resume-projects-title">{resumeContent.projectsTitle}</h2>
        </div>
        <div class="resume-long-list">
          {resumeContent.projects.map((project) => (
            <article class="resume-entry">
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <ul>
                {project.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-section" aria-labelledby="resume-experience-title">
        <div class="section-heading">
          <h2 id="resume-experience-title">{resumeContent.experienceTitle}</h2>
        </div>
        <div class="resume-long-list">
          {resumeContent.experience.map((job) => (
            <article class="resume-entry">
              <div class="resume-entry-heading">
                <h3>{job.role}</h3>
                <span>{job.period}</span>
              </div>
              <p>{job.company}</p>
              <ul>
                {job.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-section" aria-labelledby="resume-skills-title">
        <div class="section-heading">
          <h2 id="resume-skills-title">{resumeContent.skillsTitle}</h2>
        </div>
        <div class="resume-ledger">
          {resumeContent.skills.map((skillGroup) => (
            <article class="resume-row">
              <span>{skillGroup.label}</span>
              <p>{skillGroup.items.join(", ")}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-section" aria-labelledby="resume-education-title">
        <div class="section-heading">
          <h2 id="resume-education-title">{resumeContent.educationTitle}</h2>
        </div>
        <div class="resume-ledger">
          {resumeContent.education.map((education) => (
            <article class="resume-row">
              <span>{education.period}</span>
              <p><strong>{education.degree}</strong> · {education.institution}</p>
            </article>
          ))}
          <article class="resume-row">
            <span>{resumeContent.languagesTitle}</span>
            <p>{resumeContent.languages.join(", ")}</p>
          </article>
        </div>
      </section>

      <section class="resume-context" aria-labelledby="resume-context-title">
        <div class="section-heading">
          <h2 id="resume-context-title">{resumeContent.contextTitle}</h2>
          <p class="section-intro">{resumeContent.pdf.description}</p>
        </div>
        <div class="resume-context-links">
          {resumeContent.contextLinks.map((link) => (
            <a class="evidence-link" href={link.href}>
              <span>{link.label}</span>
              <strong>{link.text}</strong>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : isContact ? (
    <>
      <section class="contact-form-section" aria-labelledby="contact-title" data-contact-content-id={id}>
        <div class="contact-form-copy">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="contact-title">{variant.title}</h1>
          <p class="hero-lead">{variant.summary}</p>
          <div class="contact-direct-actions" aria-label={copy.actions}>
            <a class="button button-whatsapp" href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_hero">{contactCopy.whatsappLabel}</a>
            <a class="button button-secondary" href={directEmailHref} data-analytics-event="email_cta_clicked" data-analytics-target="contact_hero">{contactCopy.emailLabel}</a>
          </div>
          <figure class="contact-architecture-card">
            <img
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Ruta visual de contacto, entrega y observabilidad de AOHYS" : "Visual route for AOHYS contact, delivery, and observability"}
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <form
          class="contact-form"
          method="post"
          action={contactEndpoint || directEmailHref}
          data-contact-form
          data-contact-endpoint={contactEndpoint}
          data-success-message={contactCopy.successMessage}
          data-degraded-success-message={contactCopy.degradedSuccessMessage}
          data-error-message={contactCopy.errorMessage}
          data-validation-message={contactCopy.validationMessage}
          data-email-error-message={contactCopy.emailErrorMessage}
          data-backend-error-message={contactCopy.backendErrorMessage}
          data-endpoint-missing={contactCopy.endpointMissing}
          data-retry-label={contactCopy.retryLabel}
          data-analytics-view="contact_form_viewed"
          data-analytics-submit="contact_form_submit_attempted"
          data-analytics-target="contact_form"
        >
          <div class="contact-form-heading">
            <h2>{contactCopy.formTitle}</h2>
            <p>{contactCopy.formIntro}</p>
          </div>

          <label class="field-label">
            <span>{contactCopy.nameLabel}</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>

          <div class="field-grid">
            <label class="field-label">
              <span>{contactCopy.emailLabel}</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>
            <label class="field-label">
              <span>{contactCopy.phoneLabel}</span>
              <input name="phone" type="tel" autocomplete="tel" />
            </label>
          </div>

          <label class="field-label">
            <span>{contactCopy.companyLabel}</span>
            <input name="company" type="text" autocomplete="organization" />
          </label>

          <div class="field-grid">
            <label class="field-label">
              <span>{contactCopy.intentLabel}</span>
              <select name="intent" required>
                <option value="project">{contactCopy.intentProject}</option>
                <option value="hiring">{contactCopy.intentHiring}</option>
                <option value="architecture-review">{contactCopy.intentArchitecture}</option>
                <option value="website">{contactCopy.intentWebsite}</option>
                <option value="other">{contactCopy.intentOther}</option>
              </select>
            </label>

            <fieldset class="contact-choice">
              <legend>{contactCopy.preferredContactLabel}</legend>
              <label>
                <input name="preferredContactPath" type="radio" value="email" required checked />
                <span>{contactCopy.preferredEmail}</span>
              </label>
              <label>
                <input name="preferredContactPath" type="radio" value="whatsapp" required />
                <span>{contactCopy.preferredWhatsApp}</span>
              </label>
            </fieldset>
          </div>

          <label class="field-label">
            <span>{contactCopy.messageLabel}</span>
            <textarea name="message" rows="6" required></textarea>
          </label>

          <label class="consent-row">
            <input name="consentToContact" type="checkbox" value="true" required />
            <span>{contactCopy.consentLabel}</span>
          </label>

          <label class="contact-honeypot" aria-hidden="true">
            <span>Website</span>
            <input name="website" type="text" autocomplete="off" tabindex="-1" />
          </label>
          <input name="formStartedAt" type="hidden" value="" />
          <input name="sourcePath" type="hidden" value={route.path} />
          <input name="locale" type="hidden" value={locale} />
          <input name="referrer" type="hidden" value="" />

          <div class="contact-submit-row">
            <button class="button button-primary" type="submit" data-submit-label={contactCopy.submitLabel} data-sending-label={contactCopy.sendingLabel}>
              {contactCopy.submitLabel}
            </button>
            <p>{contactCopy.fallbackText} <a href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="contact_form_fallback">{contactCopy.whatsappLabel}</a></p>
          </div>
          <p class="contact-status" role="status" data-contact-status></p>
        </form>
      </section>

      <script>
        const dispatchContactAnalytics = (event: string, properties: Record<string, string | boolean> = {}) => {
          window.dispatchEvent(new CustomEvent("aohys:analytics", {
            detail: { event, properties },
          }));
        };

        const messageWithRetry = (message: string | undefined, retryLabel: string | undefined) =>
          [message, retryLabel].filter(Boolean).join(" ");

        const readErrorCode = async (response: Response) => {
          try {
            const payload = await response.json();
            return typeof payload?.code === "string" ? payload.code : "";
          } catch {
            return "";
          }
        };

        const readSubmissionResult = async (response: Response) => {
          try {
            return await response.json();
          } catch {
            return {};
          }
        };

        const stringStatus = (payload: unknown, key: string, fallback: string) => {
          if (!payload || typeof payload !== "object") {
            return fallback;
          }

          const value = (payload as Record<string, unknown>)[key];
          return typeof value === "string" && value ? value : fallback;
        };

        const shouldShowDegradedSuccess = (notificationStatus: string) =>
          notificationStatus === "failed" || notificationStatus === "skipped";

        const failureReasonForResponse = (response: Response, code: string) => {
          if (response.status === 400 || code === "validation_error") {
            return "validation_failed";
          }

          if (
            code === "email_delivery_failed" ||
            code === "provider_configuration_error" ||
            code === "analytics_delivery_failed"
          ) {
            return "email_delivery_failed";
          }

          return "backend_unavailable";
        };

        const failureMessageForReason = (form: HTMLFormElement, reason: string) => {
          if (reason === "validation_failed") {
            return form.dataset.validationMessage ?? form.dataset.errorMessage ?? "";
          }

          if (reason === "email_delivery_failed") {
            return form.dataset.emailErrorMessage ?? form.dataset.errorMessage ?? "";
          }

          return form.dataset.backendErrorMessage ?? form.dataset.errorMessage ?? "";
        };

        for (const form of document.querySelectorAll("[data-contact-form]")) {
          const endpoint = form instanceof HTMLFormElement ? form.dataset.contactEndpoint : "";
          const status = form.querySelector("[data-contact-status]");
          const startedAt = form.querySelector('input[name="formStartedAt"]');
          const referrer = form.querySelector('input[name="referrer"]');
          const submitButton = form.querySelector('button[type="submit"]');

          if (startedAt instanceof HTMLInputElement) {
            startedAt.value = String(Date.now());
          }

          if (referrer instanceof HTMLInputElement) {
            referrer.value = document.referrer;
          }

          form.addEventListener("submit", async (event) => {
            event.preventDefault();

            if (!(form instanceof HTMLFormElement)) {
              return;
            }

            if (!form.checkValidity()) {
              if (status) {
                status.textContent = messageWithRetry(
                  form.dataset.validationMessage,
                  form.dataset.retryLabel,
                );
              }
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "validation_failed",
              });
              form.reportValidity();
              return;
            }

            if (!endpoint) {
              if (status) {
                status.textContent = messageWithRetry(
                  form.dataset.endpointMissing,
                  form.dataset.retryLabel,
                );
              }
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "endpoint_missing",
              });
              return;
            }

            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());
            payload.consentToContact = formData.get("consentToContact") === "true" ? "true" : "";

            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = true;
              submitButton.textContent = submitButton.dataset.sendingLabel ?? submitButton.textContent;
            }

            try {
              const response = await fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  ...payload,
                  consentToContact: payload.consentToContact === "true",
                  formStartedAt: Number(payload.formStartedAt),
                }),
              });

              if (!response.ok) {
                const errorCode = await readErrorCode(response);
                const failureReason = failureReasonForResponse(response, errorCode);
                dispatchContactAnalytics("contact_form_submit_failed", {
                  failure_reason: failureReason,
                });
                if (status) {
                  status.textContent = messageWithRetry(
                    failureMessageForReason(form, failureReason),
                    form.dataset.retryLabel,
                  );
                }
                return;
              }

              const result = await readSubmissionResult(response);
              const notificationStatus = stringStatus(result, "notificationStatus", "unknown");
              const analyticsStatus = stringStatus(result, "analyticsStatus", "unknown");
              const deliveryDegraded = shouldShowDegradedSuccess(notificationStatus);

              dispatchContactAnalytics("contact_form_submit_succeeded", {
                notification_status: notificationStatus,
                analytics_status: analyticsStatus,
                delivery_degraded: deliveryDegraded,
              });

              form.reset();
              if (status) {
                status.textContent = deliveryDegraded
                  ? form.dataset.degradedSuccessMessage ?? form.dataset.successMessage ?? ""
                  : form.dataset.successMessage ?? "";
              }
            } catch {
              dispatchContactAnalytics("contact_form_submit_failed", {
                failure_reason: "backend_unavailable",
              });
              if (status) {
                status.textContent = messageWithRetry(
                  form.dataset.backendErrorMessage ?? form.dataset.errorMessage,
                  form.dataset.retryLabel,
                );
              }
            } finally {
              if (submitButton instanceof HTMLButtonElement) {
                submitButton.disabled = false;
                submitButton.textContent = submitButton.dataset.submitLabel ?? submitButton.textContent;
              }
            }
          });
        }
      </script>
    </>
  ) : isPrivacy && privacyContent ? (
    <>
      <section class="route-hero" aria-labelledby="privacy-title" data-privacy-content-id={id}>
        <div class="route-hero-copy">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="privacy-title">{privacyContent.heading}</h1>
          <p class="hero-lead">{privacyContent.intro}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <aside class="route-panel" aria-label={copy.routeMetadataAria}>
          <span>{copy.canonical}</span>
          <strong>{route.path}</strong>
          <span>{copy.contentType}</span>
          <strong>{node.type}</strong>
        </aside>
      </section>

      <section class="route-proof-section" aria-labelledby="privacy-sections-title">
        <div class="section-heading">
          <h2 id="privacy-sections-title">{variant.summary}</h2>
        </div>
        <div class="route-proof-list">
          {privacyContent.sections.map((section) => (
            <div class="route-proof-item">
              <span>{section.title}</span>
              <p>{section.body}</p>
            </div>
          ))}
        </div>
        <p class="privacy-boundary-note">{privacyContent.boundaryNote}</p>
      </section>
    </>
  ) : (
    <>
      <section class="route-hero" aria-labelledby="route-title" data-content-type={node.type}>
        <div class="route-hero-copy">
          <p class="signal-line">{routeSignal}</p>
          <h1 id="route-title">{variant.title}</h1>
          <p class="hero-lead">{variant.summary}</p>
          <div class="hero-actions" aria-label={copy.actions}>
            {primaryHref && <a class="button button-primary" href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class="button button-secondary" href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>
        <aside class="route-panel" aria-label={copy.routeMetadataAria}>
          <span>{copy.canonical}</span>
          <strong>{route.path}</strong>
          <span>{copy.contentType}</span>
          <strong>{node.type}</strong>
        </aside>
      </section>

      <section class="route-proof-section" aria-labelledby="route-proof-title">
        <div class="section-heading">
          <h2 id="route-proof-title">{copy.routeProofTitle}</h2>
        </div>
        <div class="route-proof-list">
          {copy.routeProof.map((item) => (
            <div class="route-proof-item">
              <span>{item.label}</span>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </section>
    </>
  )
}
