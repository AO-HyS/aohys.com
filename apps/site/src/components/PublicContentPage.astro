              <span>{contactCopy.intentLabel}</span>
              <select name="intent" required>
                <option value="project">{contactCopy.intentProject}</option>
                <option value="hiring">{contactCopy.intentHiring}</option>
                <option value="architecture-review">{contactCopy.intentArchitecture}</option>
