---
import {
  getArchitecturePageContent,
  getCaseStudyIndexContent,
  getCaseStudyPageContent,
  getHomePageContent,
  getLocalizedPath,
  getPrivacyPageContent,
  getResumePageContent,
  STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID,
  type ContentId,
  type PublicRoute,
} from "@aohys/content-graph";
import { DASHBOARD_PUBLIC_MEDIA_BY_CONTENT_ID } from "../generated/dashboard-public-media";
import { DASHBOARD_PUBLIC_SETTINGS } from "../generated/dashboard-public-settings";
import { getUiCopy } from "../i18n";
import { cx, screenshotImageClass, ui } from "../styles/classes";

interface Props {
  route: PublicRoute;
}

const { route } = Astro.props;
const { id, locale, node, variant } = route;
const isHome = id === "home";
const isArchitecture = id === "architecture";
const isCaseStudyIndex = node.type === "case-study-index";
const isCaseStudy = node.type === "case-study";
const isResume = node.type === "resume";
const isContact = node.type === "contact";
const isPrivacy = node.type === "privacy";
const copy = getUiCopy(locale).publicPage;
const contactCopy = getUiCopy(locale).contactForm;
const homeContent = isHome ? getHomePageContent(locale) : undefined;
const architectureContent = isArchitecture ? getArchitecturePageContent(locale) : undefined;
const caseStudyIndexContent = isCaseStudyIndex ? getCaseStudyIndexContent(locale) : undefined;
const caseStudyContent = isCaseStudy ? getCaseStudyPageContent(id, locale) : undefined;
const resumeContent = isResume ? getResumePageContent(locale) : undefined;
const privacyContent = isPrivacy ? getPrivacyPageContent(locale) : undefined;
const caseStudySections = caseStudyContent ? [
  caseStudyContent.problem,
  caseStudyContent.businessOutcome,
  caseStudyContent.role,
  caseStudyContent.constraints,
  caseStudyContent.architectureDecisions,
  caseStudyContent.executionHighlights,
  caseStudyContent.qualitySecurityPerformance,
] : [];

function actionHref(contentId?: ContentId): string | undefined {
  return contentId ? getLocalizedPath(contentId, locale) : undefined;
}

const primaryHref = actionHref(variant.primaryActionContentId);
const secondaryHref = actionHref(variant.secondaryActionContentId);
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";
const publicContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "alejandro.ortiz@aohys.com";
const publicWhatsAppUrl = DASHBOARD_PUBLIC_SETTINGS.PUBLIC_WHATSAPP_URL ?? import.meta.env.PUBLIC_WHATSAPP_URL ?? "https://wa.me/522299020825";
const directEmailHref = `mailto:${publicContactEmail}`;

function splitHeadline(headline: string): string[] {
  const parts = headline.split(". ");
  return parts.map((part, index) => {
    if (index < parts.length - 1 && !part.endsWith(".")) {
      return `${part}.`;
    }

    return part;
  });
}

function splitHomeHeadline(headline: string) {
  const separator = locale === "es" ? " con " : " with ";

  if (headline.includes(separator)) {
    const [first, ...rest] = headline.split(separator);
    return [
      { text: first, emphasized: false },
      { text: `${separator.trim()} ${rest.join(separator)}`, emphasized: true },
    ];
  }

  return splitHeadline(headline).map((text) => ({ text, emphasized: false }));
}

const homeHeadlineParts = homeContent ? splitHomeHeadline(homeContent.headline) : [];

const routeSignalById: Partial<Record<ContentId | string, string>> = {
  "case-studies": locale === "es" ? "Trabajo que puedo mostrar" : "Work I can show",
  architecture: locale === "es" ? "Sistema público" : "Public system",
  resume: locale === "es" ? "Contexto profesional" : "Professional context",
  contact: locale === "es" ? "Contacto directo" : "Direct contact",
  privacy: locale === "es" ? "Límite de privacidad" : "Privacy boundary",
  practice: locale === "es" ? "Práctica de ingeniería" : "Engineering practice",
};
const routeSignal = routeSignalById[id] ?? variant.summary;

const fallbackEvidenceImageByContentId: Partial<Record<ContentId | string, { src: string; thumbSrc?: string; alt: string; kind: string }>> = {
  "case-study:casa-roca": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:casa-roca"],
    alt: locale === "es" ? "Captura pública del sitio Casa Roca en producción" : "Public Casa Roca production website screenshot",
  },
  "case-study:the-barber-central": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:the-barber-central"],
    alt: locale === "es" ? "Landing page de desarrollo de The Barber Central" : "The Barber Central development landing page",
  },
  "case-study:nutri-plan": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:nutri-plan"],
    alt: locale === "es" ? "Dashboard administrativo de Nutri Plan" : "Nutri Plan administrative dashboard",
  },
  "case-study:enterprise-systems": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:enterprise-systems"],
    alt: locale === "es" ? "Mapa público seguro de trabajo enterprise confidencial" : "Public-safe map of confidential enterprise systems work",
  },
  "case-study:engineering-practice": {
    ...STATIC_EVIDENCE_IMAGE_BY_CONTENT_ID["case-study:engineering-practice"],
    alt: locale === "es" ? "Superficie visual de arquitectura pública de AOHYS" : "AOHYS public architecture proof surface",
  },
};
const evidenceImageByContentId: Partial<Record<ContentId | string, { src: string; thumbSrc?: string; alt: string; kind: string }>> = {
  ...fallbackEvidenceImageByContentId,
  ...DASHBOARD_PUBLIC_MEDIA_BY_CONTENT_ID,
};

function evidenceImageForContent(contentId: string) {
  return evidenceImageByContentId[contentId];
}

function evidenceImageForPath(path: string) {
  const normalizedPath = path.replace(/\/$/, "");
  const dynamicSlug = normalizedPath.match(/^\/case-studies\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1]
    ?? normalizedPath.match(/^\/es\/casos\/([a-z0-9]+(?:-[a-z0-9]+)*)$/)?.[1];

  if (dynamicSlug) {
    const dynamicImage = evidenceImageForContent(`case-study:${dynamicSlug}`);

    if (dynamicImage) {
      return dynamicImage;
    }
  }

  if (path.includes("casa-roca")) {
    return evidenceImageForContent("case-study:casa-roca");
  }

  if (path.includes("the-barber-central")) {
    return evidenceImageForContent("case-study:the-barber-central");
  }

  if (path.includes("nutri-plan")) {
    return evidenceImageForContent("case-study:nutri-plan");
  }

  if (path.includes("enterprise-systems") || path.includes("sistemas-enterprise")) {
    return evidenceImageForContent("case-study:enterprise-systems");
  }

  if (
    path.includes("engineering-practice") ||
    path.includes("practica-de-ingenieria") ||
    path === "/practice" ||
    path === "/es/practica"
  ) {
    return evidenceImageForContent("case-study:engineering-practice");
  }

  return undefined;
}

const caseStudyEvidenceImage = isCaseStudy ? evidenceImageForContent(id) : undefined;
const homeFeaturedOutcome = homeContent?.selectedOutcomes[0];
const homeFeaturedEvidenceImage = homeFeaturedOutcome ? evidenceImageForPath(homeFeaturedOutcome.path) : undefined;
const homeFeaturedImageSrc = homeFeaturedOutcome
  ? homeFeaturedEvidenceImage?.thumbSrc ?? homeFeaturedEvidenceImage?.src ?? homeFeaturedOutcome.evidence.src
  : undefined;
const homeFeaturedImageAlt = homeFeaturedOutcome
  ? homeFeaturedImageSrc === homeFeaturedOutcome.evidence.src
    ? homeFeaturedOutcome.evidence.altText
    : homeFeaturedEvidenceImage?.alt ?? homeFeaturedOutcome.evidence.altText
  : "";
const homeSystemNodes = locale === "es" ? [
  {
    title: "Sitio publico",
    detail: "SEO e i18n",
    bullets: ["Paginas de contenido", "Activos estaticos"],
  },
  {
    title: "Content Graph",
    detail: "Convex",
    bullets: ["Modelos de contenido", "Leads y contacto"],
  },
  {
    title: "Dashboard",
    detail: "Privado",
    bullets: ["Herramientas operativas", "Editor de media"],
  },
] : [
  {
    title: "Public site",
    detail: "SEO & i18n",
    bullets: ["Content pages", "Static assets"],
  },
  {
    title: "Content Graph",
    detail: "Convex",
    bullets: ["Content models", "Leads & contact"],
  },
  {
    title: "Dashboard",
    detail: "Private",
    bullets: ["Operational tools", "Media manager"],
  },
];
const homeArchitectureTools = [
  { name: "Cloudflare", detail: locale === "es" ? "Media delivery" : "Media delivery" },
  { name: "PostHog", detail: locale === "es" ? "Analitica y errores" : "Analytics & errors" },
  { name: "Resend", detail: locale === "es" ? "Email y notificaciones" : "Email & notifications" },
];
const homeOutcomeMetaByContentId: Record<string, { impact: string; role: string; action: string }> = {
  "case-study:casa-roca": {
    impact: locale === "es" ? "+20% reservas directas" : "+20% direct bookings",
    role: locale === "es" ? "Lead Engineer" : "Lead Engineer",
    action: locale === "es" ? "Ver caso completo" : "View full case",
  },
  "case-study:the-barber-central": {
    impact: locale === "es" ? "+3.2k reservas" : "+3.2k bookings",
    role: locale === "es" ? "Founder & Engineer" : "Founder & Engineer",
    action: locale === "es" ? "Ver caso completo" : "View full case",
  },
  "case-study:nutri-plan": {
    impact: locale === "es" ? "+40% retencion" : "+40% client retention",
    role: locale === "es" ? "Product Engineer" : "Product Engineer",
    action: locale === "es" ? "Ver caso completo" : "View full case",
  },
  "case-study:enterprise-systems": {
    impact: locale === "es" ? "Escala operativa" : "Operational scale",
    role: locale === "es" ? "Senior Engineer" : "Senior Engineer",
    action: locale === "es" ? "Ver resume" : "View resume",
  },
};
---

{
  isHome && homeContent ? (
    <>
      <section class={ui.homeProofHero} aria-labelledby="home-title" data-home-content-id={id}>
        <div class={ui.homeHeroCopy}>
          <p class={cx(ui.signalLine, ui.homeSignalLine)}>{copy.signal}</p>
          <h1 id="home-title" class={ui.homeHeadline} aria-label={homeContent.headline}>
            {homeHeadlineParts.map((part) => (
              <span aria-hidden="true">{part.emphasized ? <em>{part.text}</em> : part.text}</span>
            ))}
          </h1>
          <p class={cx(ui.heroLead, ui.homeHeroLead)}>{homeContent.deck}</p>
          <div class={cx(ui.heroActions, ui.homeHeroActions)} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnLightHero)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
          <div class={ui.homeStackStrip} aria-label={locale === "es" ? "Stack operativo" : "Operating stack"}>
            <span>{locale === "es" ? "Contenido dinamico" : "Dynamic content"} <strong>Convex</strong></span>
            <span>{locale === "es" ? "Media delivery" : "Media delivery"} <strong>Cloudflare</strong></span>
            <span>{locale === "es" ? "Analitica y errores" : "Analytics & errors"} <strong>PostHog</strong></span>
            <span>{locale === "es" ? "Email y notificaciones" : "Email & notifications"} <strong>Resend</strong></span>
          </div>
        </div>

        <figure class={ui.homeSystemBoard} aria-label={homeContent.proofBoardLabel}>
          <span class={ui.homeBoardLabel}>AOHYS System Map</span>
          <div class={ui.homeSystemMap} aria-hidden="true">
            <span class={ui.systemNodePrimary}>{homeSystemNodes[0].title}</span>
            {homeSystemNodes.map((node) => (
              <section class={ui.systemNode}>
                <strong>{node.title}</strong>
                <small>{node.detail}</small>
                {node.bullets.map((bullet) => <span>{bullet}</span>)}
              </section>
            ))}
            <span class={ui.systemConnector}></span>
            <span class={ui.systemConnectorSecondary}></span>
          </div>
          {homeFeaturedImageSrc && (
            <span class={ui.homeMiniScreenshot}>
              <img
                class={screenshotImageClass(homeFeaturedEvidenceImage?.kind ?? "site", "compact")}
                src={homeFeaturedImageSrc}
                alt={homeFeaturedImageAlt}
                loading="eager"
                decoding="async"
              />
            </span>
          )}
          <span class={ui.homeStickyNote}>
            <strong>Casa Roca</strong>
            <span>Live since 2022</span>
          </span>
          <span class={ui.homePen} aria-hidden="true"></span>
          <span class={ui.homeChartCard} aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class={ui.homeCodeCard} aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </span>
          <figcaption class={ui.homeBoardCaption}>
            <strong>{homeContent.proofBoardTitle}</strong>
            <span>{homeContent.proofBoardBody}</span>
          </figcaption>
        </figure>
      </section>

      <section class={ui.proofMetricStrip} aria-label={locale === "es" ? "Métricas de prueba pública" : "Public proof metrics"}>
        {homeContent.proofMetrics.map((metric) => (
          <article class={ui.proofMetric}>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
            <p>{metric.detail}</p>
          </article>
        ))}
      </section>

      <section class={ui.selectedOutcomes} aria-labelledby="ledger-title" data-home-section="selected-outcomes">
        <div class={ui.sectionHeading}>
          <div>
            <p class={ui.signalLine}>{copy.proofHeadingSignal}</p>
            <h2 id="ledger-title">{homeContent.selectedOutcomesHeading}</h2>
          </div>
          <a class={ui.sectionTextLink} href={getLocalizedPath("case-studies", locale)}>
            {locale === "es" ? "Ver todos los proyectos" : "View all projects"} <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class={ui.outcomeLedger}>
          {homeContent.selectedOutcomes.map((outcome) => (
            <a class={ui.outcomeRow} href={outcome.path}>
              {(() => {
                const evidenceImage = evidenceImageForPath(outcome.path);
                const imageSrc = evidenceImage?.thumbSrc ?? evidenceImage?.src ?? outcome.evidence.src;
                const imageAlt = imageSrc === outcome.evidence.src
                  ? outcome.evidence.altText
                  : evidenceImage?.alt ?? outcome.evidence.altText;

                return (
                  <figure class={ui.outcomeShot} aria-label={imageAlt}>
                    {imageSrc ? (
                      <img class={screenshotImageClass(evidenceImage?.kind ?? "site", "compact")} src={imageSrc} alt={imageAlt} loading="eager" decoding="async" />
                    ) : (
                      <span class={ui.evidenceFallback}>{outcome.evidence.label}</span>
                    )}
                  </figure>
                );
              })()}
              <div class={ui.outcomeSummary}>
                <span class={ui.outcomeStatus}>
                  {outcome.title}
                  <small>{outcome.label}</small>
                </span>
                <p class={ui.bodyMutedPretty}>{outcome.outcome}</p>
              </div>
              <div class={ui.outcomeMeta}>
                <span>{locale === "es" ? "Impacto de negocio" : "Business impact"}</span>
                <strong>{homeOutcomeMetaByContentId[outcome.contentId]?.impact ?? outcome.role}</strong>
              </div>
              <div class={ui.outcomeMeta}>
                <span>{locale === "es" ? "Rol" : "Role"}</span>
                <strong>{homeOutcomeMetaByContentId[outcome.contentId]?.role ?? outcome.role}</strong>
              </div>
              <span class={ui.outcomeCta}>{homeOutcomeMetaByContentId[outcome.contentId]?.action ?? variant.secondaryActionLabel} <span aria-hidden="true">→</span></span>
            </a>
          ))}
        </div>
      </section>

      <section class={ui.architectureStage} aria-labelledby="home-architecture-title" data-home-section="architecture">
        <div class={ui.architectureStageCopy}>
          <p class={cx(ui.signalLine, ui.darkSignalLine)}>{locale === "es" ? "Arquitectura de un vistazo" : "Architecture at a glance"}</p>
          <h2 id="home-architecture-title">{homeContent.architectureHeading}</h2>
          <p class={ui.architectureLead}>{homeContent.architectureBody}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            <a class={cx(ui.button, ui.buttonPrimary)} href={getLocalizedPath("architecture", locale)}>
              {locale === "es" ? "Ver arquitectura completa" : "View full architecture"}
            </a>
          </div>
        </div>
        <div class={ui.architectureDiagram} aria-label={homeContent.architectureHeading}>
          <div class={ui.architectureDiagramRow}>
            {homeSystemNodes.map((node) => (
              <section class={ui.architectureDiagramNode}>
                <strong>{node.title}</strong>
                <span>{node.detail}</span>
                {node.bullets.map((bullet) => <small>{bullet}</small>)}
              </section>
            ))}
          </div>
          <div class={ui.architectureServiceRow}>
            {homeArchitectureTools.map((tool) => (
              <section class={ui.architectureServiceNode}>
                <strong>{tool.name}</strong>
                <span>{tool.detail}</span>
              </section>
            ))}
          </div>
        </div>
        <div class={ui.architectureToolGrid} aria-label={locale === "es" ? "Responsabilidades del sistema" : "System responsibilities"}>
          <span>Edge delivery <strong>Cloudflare Pages</strong></span>
          <span>Auth & sessions <strong>Better Auth</strong></span>
          <span>Observability <strong>PostHog</strong></span>
          <span>Transactional email <strong>Resend</strong></span>
        </div>
      </section>

      <section class={ui.practiceSection} aria-labelledby="practice-title" data-home-section="practice">
        <div>
          <div class={ui.sectionHeading}>
            <p class={ui.signalLine}>{locale === "es" ? "Como trabajo" : "How I work"}</p>
            <h2 id="practice-title">{homeContent.practiceHeading}</h2>
          </div>
          <div class={ui.practiceList}>
            {homeContent.practicePoints.map((point, index) => (
              <div class={ui.practiceItem}>
                <span class={ui.practiceIcon}>{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <strong>{point.label}</strong>
                  <p>{point.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <figure class={ui.practiceArtifact} aria-label={locale === "es" ? "Artefacto operativo de entrega AOHYS" : "AOHYS delivery operating artifact"}>
          <div class={ui.practiceArtifactPanel} aria-hidden="true">
            <div class={ui.practiceArtifactChrome}>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class={ui.practiceArtifactShell}>
              <aside>
                <span>Overview</span>
                <span>Leads</span>
                <span>Projects</span>
                <span>Media</span>
                <span>Resume</span>
                <span>Settings</span>
              </aside>
              <main>
                <strong>Overview</strong>
                <div class={ui.practiceArtifactStats}>
                  {homeContent.proofMetrics.slice(0, 4).map((metric) => (
                    <span>
                      <small>{metric.label}</small>
                      <strong>{metric.value}</strong>
                    </span>
                  ))}
                </div>
                <div class={ui.practiceArtifactRows}>
                  {homeContent.practicePoints.map((point) => (
                    <span>
                      <strong>{point.label}</strong>
                      {point.text}
                    </span>
                  ))}
                </div>
              </main>
            </div>
          </div>
        </figure>
      </section>

      <section class={ui.engagementSection} aria-labelledby="engagement-title" data-home-section="engagement">
        <div class={ui.sectionHeading}>
          <div>
            <p class={ui.signalLine}>{locale === "es" ? "Modelos de trabajo" : "Engagement models"}</p>
            <h2 id="engagement-title">{homeContent.engagementHeading}</h2>
          </div>
          <p class={ui.sectionIntro}>{homeContent.engagementBody}</p>
        </div>
        <div class={ui.engagementGrid}>
          {homeContent.engagementModels.map((model, index) => (
            <article class={ui.engagementCard}>
              <span class={ui.engagementIcon}>{String(index + 1).padStart(2, "0")}</span>
              <h3>{model.title}</h3>
              <p>{model.subtitle}</p>
              <ul>
                {model.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
              <a href={getLocalizedPath("contact", locale)}>{variant.primaryActionLabel}</a>
            </article>
          ))}
        </div>
      </section>

      <section class={ui.contactBand} aria-labelledby="home-contact-title" data-home-section="contact">
        <div>
          <p class={ui.signalLine}>{locale === "es" ? "Hemos trabajado con" : "Proof before contact"}</p>
          <h2>{homeContent.faqHeading}</h2>
          <p>{homeContent.faqBody}</p>
          <div class={ui.faqList}>
            {homeContent.faqItems.map((item) => (
              <details class={ui.faqItem}>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
        <aside class={ui.contactCard}>
          <div class={ui.contactCardIntro}>
            <p class={ui.signalLine}>{locale === "es" ? "Iniciar conversacion" : "Start a conversation"}</p>
            <h2 id="home-contact-title">{homeContent.contactHeading}</h2>
            <p>{homeContent.contactBody}</p>
          </div>
          <form class={ui.homeContactForm} method="post" action={contactEndpoint || directEmailHref}>
            <div class={ui.fieldGrid}>
              <label class={ui.fieldLabel}>
                <span>{contactCopy.nameLabel}</span>
                <input name="name" type="text" autocomplete="name" required />
              </label>
              <label class={ui.fieldLabel}>
                <span>{contactCopy.emailLabel}</span>
                <input name="email" type="email" autocomplete="email" required />
              </label>
            </div>
            <label class={ui.fieldLabel}>
              <span>{contactCopy.messageLabel}</span>
              <textarea name="message" rows="5" required></textarea>
            </label>
            <button class={cx(ui.button, ui.buttonPrimary)} type="submit">
              {contactCopy.submitLabel} <span aria-hidden="true">→</span>
            </button>
          </form>
          <div class={ui.contactActions} aria-label={copy.actions}>
            <a href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="home_contact_band">{contactCopy.whatsappLabel}</a>
            <a href={directEmailHref} data-analytics-event="email_cta_clicked" data-analytics-target="home_contact_band">{publicContactEmail}</a>
          </div>
        </aside>
      </section>
    </>
  ) : isArchitecture && architectureContent ? (
    <>
      <section class={ui.architecturePageHero} aria-labelledby="architecture-title" data-architecture-content-id={id}>
        <div class={ui.architecturePageCopy}>
          <p class={cx(ui.signalLine, "!text-[color:var(--color-dark-muted)]")}>{routeSignal}</p>
          <h1 id="architecture-title">{architectureContent.heading}</h1>
          <p class={cx(ui.heroLead, "!text-[color:var(--color-dark-muted)]")}>{architectureContent.deck}</p>
          <div class={ui.heroActions} aria-label={copy.actions}>
            {primaryHref && <a class={cx(ui.button, ui.buttonPrimary)} href={primaryHref}>{variant.primaryActionLabel}</a>}
            {secondaryHref && <a class={cx(ui.button, ui.buttonSecondaryOnDark)} href={secondaryHref}>{variant.secondaryActionLabel}</a>}
          </div>
        </div>

        <div class={ui.architectureHeroAside}>
          <figure class={ui.darkPanelFigure}>
            <img
              class="w-full aspect-video object-cover object-center"
              src="/images/proof/aohys-system-map.svg"
              alt={locale === "es" ? "Mapa de arquitectura de la muestra pública AOHYS" : "Architecture map for the AOHYS public sample"}
              loading="eager"
              decoding="async"
            />
          </figure>
          <aside class={cx(ui.sourceIndex, ui.sourceIndexDark)} aria-label={architectureContent.sourceLabel}>
            <strong>{architectureContent.sourceLabel}</strong>
            <div class={cx(ui.sourceLinks, ui.sourceLinksDark)}>
              {architectureContent.sourceLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <section class={ui.architectureMap} aria-labelledby="architecture-map-title">
        <div class={ui.sectionHeading}>
          <h2 id="architecture-map-title">{variant.title}</h2>
          <p class={ui.sectionIntro}>{variant.summary}</p>
        </div>
        <div class={ui.rowList}>
          {architectureContent.sections.map((section) => (
            <article class={ui.architectureRow}>
              <h3>{section.title}</h3>
              <p>{section.body}</p>
