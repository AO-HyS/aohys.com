---
import { getLocalizedPath, type Locale } from "@aohys/content-graph";
import { DASHBOARD_PUBLIC_SETTINGS } from "../generated/dashboard-public-settings";
import { getUiCopy } from "../i18n";

interface Props { locale?: Locale; }

const year = new Date().getFullYear();
const { locale = "en" } = Astro.props;
const copy = getUiCopy(locale).footer;
const publicContactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "alejandro.ortiz@aohys.com";
const publicWhatsAppUrl = DASHBOARD_PUBLIC_SETTINGS.PUBLIC_WHATSAPP_URL ?? import.meta.env.PUBLIC_WHATSAPP_URL ?? "https://wa.me/522299020825";
const publicRepositoryUrl = import.meta.env.PUBLIC_REPOSITORY_URL ?? "https://github.com/AO-HyS/aohys.com";
---

<footer class="sunlit-footer">
  <div class="sunlit-footer-stage">
    <span class="sunlit-footer-mark" aria-hidden="true">✦</span>
    <div class="sunlit-footer-identity">
      <p>{copy.kicker}</p>
      <h2>{copy.body}</h2>
      <small>{copy.boundary}</small>
    </div>
    <a href={getLocalizedPath("contact", locale)}>{copy.start}<span aria-hidden="true">→</span></a>
  </div>

  <div class="sunlit-footer-links" aria-label={copy.linksAria}>
    <a href={getLocalizedPath("case-studies", locale)}>{copy.work}</a>
    <a href={getLocalizedPath("practice", locale)}>{locale === "es" ? "Práctica" : "Practice"}</a>
    <a href={getLocalizedPath("architecture", locale)}>{copy.architecture}</a>
    <a href={getLocalizedPath("resume", locale)}>{copy.resume}</a>
    <a href={getLocalizedPath("privacy", locale)}>{copy.privacy}</a>
    <a href={publicRepositoryUrl}>{copy.repository}</a>
    <a href={`mailto:${publicContactEmail}`} data-analytics-event="email_cta_clicked" data-analytics-target="site_footer">{copy.social.email}</a>
    <a href={publicWhatsAppUrl} data-analytics-event="whatsapp_cta_clicked" data-analytics-target="site_footer">{copy.social.whatsapp}</a>
  </div>

  <div class="sunlit-footer-base">
    <p><strong>AOHYS</strong> © {year} · {copy.copyright}</p>
    <a href="/dashboard">{copy.dashboard}</a>
  </div>
</footer>

<style>
  .sunlit-footer {
    width: var(--container);
    margin: clamp(5rem, 10vw, 9rem) auto 1.5rem;
    border: 2px solid var(--color-ink);
    background: var(--color-bg);
    box-shadow: 0 7px 0 var(--color-ink);
  }
  .sunlit-footer-stage {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1rem, 2.5vw, 1.75rem);
    background: var(--color-secondary);
  }
  .sunlit-footer-identity { display: grid; min-width: 0; grid-template-columns: minmax(15rem, .85fr) minmax(15rem, 1fr); align-items: center; gap: 1rem clamp(1.5rem, 4vw, 4rem); }
  .sunlit-footer-stage p { grid-column: 1; margin: 0 0 .25rem; font-size: .78rem; font-weight: 720; }
  .sunlit-footer-stage h2 {
    grid-column: 1;
    margin: 0;
    font-size: clamp(1.25rem, 1.6vw, 1.65rem);
    font-weight: 720;
    line-height: 1.15;
  }
  .sunlit-footer-stage small { grid-row: 1 / 3; grid-column: 2; display: block; max-width: 52ch; color: var(--color-secondary-ink); font-family: var(--font-body, inherit); font-size: .88rem; line-height: 1.45; }
  .sunlit-footer-mark { display: grid; width: 3rem; height: 3rem; place-items: center; border: 2px solid var(--color-ink); border-radius: 50%; background: var(--color-primary); color: var(--color-ink); font-size: 1.2rem; }
  .sunlit-footer-stage > a {
    display: inline-flex;
    align-items: center;
    gap: .65rem;
    padding: .6rem 0 .45rem;
    border-bottom: 2px solid var(--color-ink);
    text-decoration: none;
    font-size: .9rem;
    font-weight: 720;
    white-space: nowrap;
  }
  .sunlit-footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 2px solid var(--color-ink);
  }
  .sunlit-footer-links a {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    padding: 0 1rem;
    border-right: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
    font-size: .9rem;
    font-weight: 680;
  }
  .sunlit-footer-links a:hover { background: var(--color-primary); }
  .sunlit-footer-base {
    display: flex;
    min-height: 4rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: .75rem 1rem;
    font-size: .84rem;
  }
  .sunlit-footer-base p { margin: 0; }
  .sunlit-footer-base a { color: var(--color-muted); }
  @media (max-width: 720px) {
    .sunlit-footer-stage { grid-template-columns: auto minmax(0, 1fr); align-items: start; }
    .sunlit-footer-identity { grid-template-columns: 1fr; gap: .25rem; }
    .sunlit-footer-stage small { grid-row: auto; grid-column: 1; margin-top: .35rem; }
    .sunlit-footer-stage > a { grid-column: 2; justify-self: start; }
    .sunlit-footer-links { grid-template-columns: repeat(2, 1fr); }
    .sunlit-footer-base { align-items: flex-start; flex-direction: column; }
  }
</style>
