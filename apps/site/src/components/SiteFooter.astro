---
import { getLocalizedPath, type Locale } from "@aohys/content-graph";
import { getUiCopy } from "../i18n";

interface Props {
  locale?: Locale;
}

const year = new Date().getFullYear();
const { locale = "en" } = Astro.props;
const copy = getUiCopy(locale).footer;
---

<footer class="site-footer">
  <div>
    <p class="footer-kicker">{copy.kicker}</p>
    <p>
      {copy.body}
    </p>
  </div>
  <div class="footer-links" aria-label={copy.linksAria}>
    <a href={getLocalizedPath("privacy", locale)}>{copy.privacy}</a>
    <a href={getLocalizedPath("architecture", locale)}>{copy.architecture}</a>
    <a class="footer-dashboard-link" href="/dashboard">{copy.dashboard}</a>
    <a href="mailto:alejandro.ortiz@aohys.com">alejandro.ortiz@aohys.com</a>
  </div>
  <p class="copyright">© {year} AOH&amp;S. {copy.copyright}</p>
</footer>
