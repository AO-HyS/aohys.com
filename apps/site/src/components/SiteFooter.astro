---
import { getLocalizedPath, type Locale } from "@aohys/content-graph";
import { getUiCopy } from "../i18n";
import { ui } from "../styles/classes";

interface Props {
  locale?: Locale;
}

const year = new Date().getFullYear();
const { locale = "en" } = Astro.props;
const copy = getUiCopy(locale).footer;
---

<footer class={ui.siteFooter}>
  <div>
    <p class={ui.footerKicker}>{copy.kicker}</p>
    <p>
      {copy.body}
    </p>
  </div>
  <div class={ui.footerLinks} aria-label={copy.linksAria}>
    <a href={getLocalizedPath("privacy", locale)}>{copy.privacy}</a>
    <a href={getLocalizedPath("architecture", locale)}>{copy.architecture}</a>
    <a class={ui.footerDashboardLink} href="/dashboard">{copy.dashboard}</a>
    <a href="mailto:alejandro.ortiz@aohys.com">alejandro.ortiz@aohys.com</a>
  </div>
  <p class={ui.copyright}>© {year} AOH&amp;S. {copy.copyright}</p>
</footer>
