---
import { getLocalizedPath, type ContentId, type Locale } from "@aohys/content-graph";

interface Props {
  locale?: Locale;
  currentId?: ContentId | string;
}

const { locale = "en", currentId = "home" } = Astro.props;
const alternateLocale = locale === "en" ? "es" : "en";
const copy = {
  en: {
    skip: "Skip to content",
    aria: "Primary",
    homeLabel: "AOHYS home",
    small: "Public source site",
    language: "Español",
  },
  es: {
    skip: "Saltar al contenido",
    aria: "Principal",
    homeLabel: "Inicio de AOHYS",
    small: "Muestra pública",
    language: "English",
  },
} as const;
const navItems = [
  { id: "case-studies", label: { en: "Selected work", es: "Casos" } },
  { id: "architecture", label: { en: "Architecture", es: "Arquitectura" } },
  { id: "resume", label: { en: "Resume", es: "CV" } },
  { id: "contact", label: { en: "Contact", es: "Contacto" } },
] as const;
const languageHref = getLocalizedPath(currentId, alternateLocale);
---

<header class="site-header">
  <a class="skip-link" href="#main-content">{copy[locale].skip}</a>
  <nav class="site-nav" aria-label={copy[locale].aria}>
    <a class="brand-lockup" href={getLocalizedPath("home", locale)} aria-label={copy[locale].homeLabel}>
      <span class="brand-mark" aria-hidden="true">AO</span>
      <span class="brand-text">
        <span>AOH&amp;S</span>
        <small>{copy[locale].small}</small>
      </span>
    </a>
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={getLocalizedPath(item.id, locale)}>{item.label[locale]}</a>
        ))
      }
      <a class="language-link" href={languageHref} hreflang={alternateLocale}>{copy[locale].language}</a>
    </div>
  </nav>
</header>
