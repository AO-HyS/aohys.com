---
import { getLocalizedPath, type ContentId, type Locale } from "@aohys/content-graph";
import { getUiCopy } from "../i18n";

interface Props {
  locale?: Locale;
  currentId?: ContentId | string;
}

const { locale = "en", currentId = "home" } = Astro.props;
const alternateLocale = locale === "en" ? "es" : "en";
const copy = getUiCopy(locale).header;
const navItems = [
  { id: "case-studies", label: copy.nav.caseStudies },
  { id: "architecture", label: copy.nav.architecture },
  { id: "resume", label: copy.nav.resume },
  { id: "contact", label: copy.nav.contact },
] as const;
const languageHref = getLocalizedPath(currentId, alternateLocale);
---

<header class="site-header">
  <a class="skip-link" href="#main-content">{copy.skip}</a>
  <nav class="site-nav" aria-label={copy.aria}>
    <a class="brand-lockup" href={getLocalizedPath("home", locale)}>
      <span class="brand-symbol" aria-hidden="true">
        <img class="brand-mark" src="/images/brand/aohys-logo.png" alt="" width="44" height="44" decoding="async" />
      </span>
      <span class="brand-text">
        <span>AOH&amp;S</span>
        <small>{copy.small}</small>
      </span>
    </a>
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={getLocalizedPath(item.id, locale)}>{item.label}</a>
        ))
      }
      <a class="language-link" href={languageHref} hreflang={alternateLocale}>{copy.language}</a>
    </div>
  </nav>
</header>
