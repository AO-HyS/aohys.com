---
import { getLocalizedPath, type ContentId, type Locale } from "@aohys/content-graph";
import { getUiCopy } from "../i18n";
import { ui } from "../styles/classes";

interface Props {
  locale?: Locale;
  currentId?: ContentId | string;
}

const { locale = "en", currentId = "home" } = Astro.props;
const alternateLocale = locale === "en" ? "es" : "en";
const copy = getUiCopy(locale).header;
const navItems = [
  { id: "case-studies", label: copy.nav.caseStudies },
  { id: "architecture", label: copy.nav.architecture },
  { id: "practice", label: copy.nav.practice },
  { id: "resume", label: copy.nav.resume },
] as const;
const languageHref = getLocalizedPath(currentId, alternateLocale);
const contactHref = getLocalizedPath("contact", locale);
---

<header class={ui.siteHeader}>
  <a class={ui.skipLink} href="#main-content">{copy.skip}</a>
  <nav class={ui.siteNav} aria-label={copy.aria}>
    <a class={ui.brandLockup} href={getLocalizedPath("home", locale)}>
      <span class={ui.brandText}>
        <span>AOHYS</span>
        <small>{copy.small}</small>
      </span>
    </a>
    <div class={ui.navLinks}>
      {
        navItems.map((item) => (
          <a href={getLocalizedPath(item.id, locale)}>{item.label}</a>
        ))
      }
    </div>
    <div class={ui.navActions}>
      <a class={ui.navLanguage} href={languageHref} hreflang={alternateLocale}>{copy.language}</a>
      <a class={ui.navCta} href={contactHref}>{copy.nav.contact}</a>
    </div>
  </nav>
</header>
