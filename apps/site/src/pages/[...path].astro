---
import { getPublicRouteMap, getSeoMetadata } from "@aohys/content-graph";
import PublicContentPage from "../components/PublicContentPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return getPublicRouteMap()
    .filter((route) => route.path !== "/")
    .map((route) => ({
      params: { path: route.path.replace(/^\/|\/$/g, "") },
      props: { route },
    }));
}

const { route } = Astro.props;
const seo = getSeoMetadata(route.id, route.locale);
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  locale={seo.lang}
  canonicalUrl={seo.canonicalUrl}
  alternates={seo.alternates}
  robots={seo.robots}
  contentId={route.id}
>
  <PublicContentPage route={route} />
</BaseLayout>
