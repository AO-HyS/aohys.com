---
import PostHogAnalytics from "../components/PostHogAnalytics.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "@fontsource-variable/mona-sans/index.css";
import "@fontsource-variable/atkinson-hyperlegible-next/index.css";
import "../styles/global.css";
import { bodyClass, ui } from "../styles/classes";
import type { ContentId, Locale } from "@aohys/content-graph";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalUrl: string;
  alternates: Record<Locale | "x-default", string>;
  robots?: string;
  contentId?: ContentId | string;
}

const {
  title,
  description,
  locale,
  canonicalUrl,
  alternates,
  robots = "index,follow",
  contentId,
} = Astro.props;

const analyticsEnvironment = import.meta.env.AOHYS_ENV ?? "local";
const analyticsPath = (() => {
  try {
    return new URL(canonicalUrl).pathname || "/";
  } catch {
    return "/";
  }
})();
---

<!doctype html>
<html lang={locale} class="scroll-smooth motion-reduce:scroll-auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta property="og:site_name" content="AOHYS" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />
    {
      Object.entries(alternates).map(([hreflang, href]) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <div class={ui.siteShell} data-site-shell="public" data-content-id={contentId}>
      <SiteHeader locale={locale} currentId={contentId} />
      <main id="main-content">
        <slot />
      </main>
      <SiteFooter locale={locale} />
    </div>
    <PostHogAnalytics
      contentId={contentId}
      locale={locale}
      canonicalUrl={canonicalUrl}
      path={analyticsPath}
      environment={analyticsEnvironment}
    />
  </body>
</html>
