# AOHYS Environment Contract example values.
# Copy to .env.local for local development. Do not commit real secrets.

AOHYS_ENV=local
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_CONTACT_ENDPOINT=

# PostHog public browser configuration.
# Preview and production must use different PostHog project keys.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_POSTHOG_AUTOCAPTURE=false

# Convex provider outputs.
CONVEX_URL=
CONVEX_DEPLOYMENT=
CONVEX_SITE_URL=
CONVEX_DEPLOY_KEY=

# Resend server-side notification configuration.
RESEND_API_KEY=
RESEND_FROM="Alejandro Ortiz <contact@aohys.com>"
LEAD_NOTIFICATION_EMAIL=alejandro.ortiz@aohys.com

# Better Auth server-side configuration.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:4321
ADMIN_EMAIL=alejandro.ortiz@aohys.com
DASHBOARD_API_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare release/media configuration.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=aohys-com
# Optional until the Cloudflare Images plan is activated for this account.
CLOUDFLARE_IMAGES_ACCOUNT_HASH=

# Public contact configuration.
PUBLIC_CONTACT_EMAIL=alejandro.ortiz@aohys.com
PUBLIC_WHATSAPP_URL=
